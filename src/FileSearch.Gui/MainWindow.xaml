<Window x:Class="FileSearch.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FileSearch.Gui.ViewModels"
        xmlns:conv="clr-namespace:FileSearch.Gui.Converters"
        xmlns:hl="clr-namespace:FileSearch.Gui.Highlighting"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="FileSearch"
        Height="820"
        Width="1360"
        MinHeight="660"
        MinWidth="1120">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:FileTypeToBrushConverter x:Key="TypeBrush"/>
        <conv:FileTypeToLabelConverter x:Key="TypeLabel"/>
    </Window.Resources>

    <DockPanel Style="{StaticResource AppRootStyle}">

        <!-- ===== Title bar (menu lives here; caption buttons sit to the right) ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource TitleBarStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/FileSearch-256.png" Width="18" Height="18" Margin="2,0,8,0"/>
                <TextBlock Text="FileSearch" Style="{StaticResource TitleTextStyle}" Margin="0,0,18,0"/>
                <Menu Style="{StaticResource TitleMenuStyle}">
                    <MenuItem Header="_File">
                        <MenuItem Header="_Install Windows integration"
                                  Command="{Binding InstallWindowsIntegrationCommand}"/>
                        <MenuItem Header="_Remove Windows integration"
                                  Command="{Binding RemoveWindowsIntegrationCommand}"/>
                        <Separator/>
                        <MenuItem Header="_Settings..." Click="OnSettingsClick"/>
                        <Separator/>
                        <MenuItem Header="E_xit" Click="OnExitClick"/>
                    </MenuItem>
                    <MenuItem Header="_Search">
                        <MenuItem Header="_Start" Command="{Binding Search.SearchCommand}" InputGestureText="Enter"/>
                        <MenuItem Header="_Cancel" Command="{Binding Search.CancelCommand}" InputGestureText="Esc"/>
                        <Separator/>
                        <MenuItem Header="_Regex tester..." Click="OnRegexTesterClick"/>
                        <MenuItem Header="_Workflows..." Click="OnWorkflowsClick"/>
                    </MenuItem>
                    <MenuItem Header="_Index">
                        <MenuItem Header="_Manage indexed locations..."
                                  Click="OnManageIndexesClick"/>
                        <MenuItem Header="_Pause background indexing"
                                  Command="{Binding Index.PauseBackgroundIndexingCommand}"/>
                        <MenuItem Header="_Resume background indexing"
                                  Command="{Binding Index.ResumeBackgroundIndexingCommand}"/>
                        <Separator/>
                        <MenuItem Header="_Open index location"
                                  Command="{Binding Index.OpenIndexLocationCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Theme">
                            <MenuItem Header="_Atlas (light)" Command="{Binding ApplyThemeCommand}" CommandParameter="Light"/>
                            <MenuItem Header="_Dark" Command="{Binding ApplyThemeCommand}" CommandParameter="Dark"/>
                            <MenuItem Header="Visual _Studio" Command="{Binding ApplyThemeCommand}" CommandParameter="VisualStudio"/>
                            <Separator/>
                            <MenuItem Header="S_ystem" Command="{Binding ApplyThemeCommand}" CommandParameter="System"/>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_User guide" Click="OnHelpClick"/>
                        <Separator/>
                        <MenuItem Header="_About" Click="OnAboutClick"/>
                    </MenuItem>
                </Menu>
            </StackPanel>
        </Border>

        <!-- ===== Status bar ===== -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7"
                         Fill="{DynamicResource Atlas.AccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Status.Text}" Style="{StaticResource StatusTextStyle}"/>
                <TextBlock Grid.Column="3" Style="{StaticResource StatusStrongStyle}" Margin="16,0,0,0">
                    <Run Text="{Binding Search.FilesMatched, Mode=OneWay}"/><Run Text=" files · "/><Run Text="{Binding Search.TotalHits, Mode=OneWay}"/><Run Text=" hits"/>
                </TextBlock>
                <TextBlock Grid.Column="4" Style="{StaticResource StatusTextStyle}" Margin="16,0,0,0">
                    <Run Text="elapsed "/><Run Text="{Binding Search.ElapsedText, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Grid.Column="5" Text="{Binding Index.IndexActivityText}"
                           Style="{StaticResource StatusTextStyle}" Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- ===== Center shell ===== -->
        <Grid x:Name="ShellRoot" Style="{StaticResource ShellStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="360" MinWidth="300" MaxWidth="720"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Sidebar ===== -->
            <Border Grid.Column="0" Style="{StaticResource SidebarStyle}">
                <DockPanel>
                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,0,14">
                        <Border Width="28" Height="28" CornerRadius="9" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2F7D57" Offset="0"/>
                                    <GradientStop Color="#37926A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="#FFFFFF"/>
                        </Border>
                        <TextBlock Text="FileSearch" Style="{StaticResource LogoTextStyle}"/>
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <TextBlock Text="THEME" Style="{StaticResource NavSectionLabelStyle}"/>
                        <UniformGrid Columns="4" Rows="1" Margin="6,0,6,8">
                            <Button Content="Atlas" Command="{Binding ApplyThemeCommand}" CommandParameter="Light"
                                    Style="{StaticResource ThemeMiniButtonStyle}" Margin="0,0,5,0"/>
                            <Button Content="Dark" Command="{Binding ApplyThemeCommand}" CommandParameter="Dark"
                                    Style="{StaticResource ThemeMiniButtonStyle}" Margin="0,0,5,0"/>
                            <Button Content="VS" Command="{Binding ApplyThemeCommand}" CommandParameter="VisualStudio"
                                    Style="{StaticResource ThemeMiniButtonStyle}" Margin="0,0,5,0"/>
                            <Button Content="Sys" Command="{Binding ApplyThemeCommand}" CommandParameter="System"
                                    Style="{StaticResource ThemeMiniButtonStyle}"/>
                        </UniformGrid>
                        <Button Click="OnWorkflowsClick" Style="{StaticResource NavItemButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8F1;" FontSize="14" Margin="0,0,11,0"/>
                                <TextBlock Text="Workflows" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnSettingsClick" Style="{StaticResource NavItemButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE713;" FontSize="14" Margin="0,0,11,0"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnHelpClick" Style="{StaticResource NavItemButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE897;" FontSize="14" Margin="0,0,11,0"/>
                                <TextBlock Text="User guide" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnAboutClick" Style="{StaticResource NavItemButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE946;" FontSize="14" Margin="0,0,11,0"/>
                                <TextBlock Text="About" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Collapsible sections. Each expanded section's row takes the
                         leftover space (*) while collapsed sections shrink to their
                         header (Auto), so collapsing one sinks it to the bottom and
                         gives the still-open sections the freed room. When the
                         sections outgrow the sidebar, the whole stack scrolls as
                         one; the MinHeight binding keeps the sink-to-bottom layout
                         while everything still fits. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False">
                    <Grid MinHeight="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                          Margin="0,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="ScopesRow" Height="Auto"/>
                            <RowDefinition x:Name="WorkspacesRow" Height="Auto"/>
                            <RowDefinition x:Name="RecentRow" Height="Auto"/>
                            <RowDefinition x:Name="FavoritesRow" Height="Auto"/>
                            <RowDefinition x:Name="IndexRow" Height="Auto"/>
                            <RowDefinition x:Name="SavedRow" Height="*"/>
                        </Grid.RowDefinitions>
                            <Expander x:Name="ScopesSection" Grid.Row="0"
                                      Header="SCOPES" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Bottom">
                                        <Button Click="OnAddScopeClick" Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE710;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="New scope" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding History.ClearCustomScopesCommand}" Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="Clear scopes" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding History.ScopeList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding History.ScopeList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding History.ScopeList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding History.ScopeList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding History.ScopeList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding History.ScopeList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding History.ScopeList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search scopes"/>
                                        <Button Command="{Binding History.ScopeList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding History.ScopeList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding History.ScopeList.Items}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Command="{Binding DataContext.Search.ApplyFilePatternPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding FileNamePattern}"
                                                            HorizontalContentAlignment="Stretch"
                                                            Style="{StaticResource NavItemButtonStyle}"
                                                            ToolTip="{Binding Summary}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ui:FontIcon Glyph="{Binding Glyph}" FontSize="14" Margin="0,0,11,0"/>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedValueStyle}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.History.RemoveCustomScopeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding CustomScope}"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Width="24" Height="24"
                                                            Margin="2,0,0,0"
                                                            VerticalAlignment="Center"
                                                            ToolTip="Remove scope"
                                                            Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibility}}">
                                                        <ui:FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Expander>

                            <Expander x:Name="WorkspacesSection" Grid.Row="1"
                                      Header="WORKSPACES" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Bottom">
                                        <Button Command="{Binding Search.SaveWorkspaceCommand}"
                                                Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE74E;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="Save current workspace" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding History.ImportWorkspaceCommand}"
                                                Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE8B5;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="Import workspace" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding History.ExportAllWorkspacesCommand}"
                                                Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE8B6;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="Export workspaces" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding History.ClearWorkspacesCommand}"
                                                Style="{StaticResource NavItemButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,11,0"/>
                                                <TextBlock Text="Clear workspaces" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding History.WorkspaceList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding History.WorkspaceList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding History.WorkspaceList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding History.WorkspaceList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding History.WorkspaceList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding History.WorkspaceList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding History.WorkspaceList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search workspaces"/>
                                        <Button Command="{Binding History.WorkspaceList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding History.WorkspaceList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding History.WorkspaceList.Items}"
                                             SelectedItem="{Binding Search.SelectedWorkspace, Mode=TwoWay}"
                                             Style="{StaticResource NavListBoxStyle}"
                                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding Summary}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:FontIcon Glyph="&#xE8F1;" FontSize="13" Margin="0,0,10,0"
                                                                 Foreground="{DynamicResource Atlas.AccentBrush}"
                                                                 VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedValueStyle}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Margin="4,0,0,0">
                                                        <Button Command="{Binding DataContext.History.ExportWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Width="24" Height="24"
                                                                ToolTip="Export workspace">
                                                            <ui:FontIcon Glyph="&#xE8B6;" FontSize="11"/>
                                                        </Button>
                                                        <Button Command="{Binding DataContext.History.RemoveWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Width="24" Height="24"
                                                                Margin="2,0,0,0"
                                                                ToolTip="Remove workspace">
                                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Expander>

                            <Expander x:Name="RecentSection" Grid.Row="2"
                                      Header="RECENT FOLDERS" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <Button DockPanel.Dock="Bottom"
                                            Command="{Binding History.ClearRecentPathsCommand}"
                                            Style="{StaticResource NavItemButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,11,0"/>
                                            <TextBlock Text="Clear recent folders" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding History.RecentPathList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding History.RecentPathList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding History.RecentPathList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding History.RecentPathList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding History.RecentPathList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding History.RecentPathList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding History.RecentPathList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search recent folders"/>
                                        <Button Command="{Binding History.RecentPathList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding History.RecentPathList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding History.RecentPathList.Items}"
                                             SelectedItem="{Binding Search.SelectedRecentPath, Mode=TwoWay}"
                                             Style="{StaticResource NavListBoxStyle}"
                                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:FontIcon Glyph="&#xE8B7;" FontSize="13" Margin="0,0,10,0"
                                                                 Foreground="{DynamicResource Atlas.WarmBrush}"
                                                                 VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.History.RemoveRecentPathCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Width="24" Height="24"
                                                            Margin="4,0,0,0"
                                                            ToolTip="Remove from recent folders">
                                                        <ui:FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Expander>

                            <Expander x:Name="FavoritesSection" Grid.Row="3"
                                      Header="FAVORITES" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <Button DockPanel.Dock="Bottom"
                                            Command="{Binding History.ClearFavoriteResultsCommand}"
                                            Style="{StaticResource NavItemButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,11,0"/>
                                            <TextBlock Text="Clear favorites" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding History.FavoriteResultList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding History.FavoriteResultList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding History.FavoriteResultList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding History.FavoriteResultList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding History.FavoriteResultList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding History.FavoriteResultList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding History.FavoriteResultList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search favorites"/>
                                        <Button Command="{Binding History.FavoriteResultList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding History.FavoriteResultList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding History.FavoriteResultList.Items}"
                                             Style="{StaticResource NavListBoxStyle}"
                                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding Path}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.ColumnSpan="2"
                                                            Command="{Binding DataContext.Search.OpenFavoriteResultCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalContentAlignment="Stretch"
                                                            Style="{StaticResource NavItemButtonStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ui:FontIcon Glyph="&#xE735;" FontSize="13" Margin="0,0,10,0"
                                                                         Foreground="{DynamicResource Atlas.AccentBrush}"
                                                                         VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Folder}" Style="{StaticResource MutedValueStyle}" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.History.RemoveFavoriteResultCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Width="24" Height="24"
                                                            Margin="4,0,0,0"
                                                            ToolTip="Remove favorite">
                                                        <ui:FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Expander>

                            <Expander x:Name="IndexSection" Grid.Row="4"
                                      Header="INDEXED LOCATIONS" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <Button DockPanel.Dock="Bottom"
                                            Click="OnManageIndexesClick"
                                            Style="{StaticResource NavItemButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE713;" FontSize="14" Margin="0,0,11,0"/>
                                            <TextBlock Text="Manage locations" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding Index.IndexedLocationList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding Index.IndexedLocationList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding Index.IndexedLocationList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Index.IndexedLocationList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding Index.IndexedLocationList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding Index.IndexedLocationList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding Index.IndexedLocationList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search indexed locations"/>
                                        <Button Command="{Binding Index.IndexedLocationList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding Index.IndexedLocationList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding Index.IndexedLocationList.Items}"
                                             SelectedItem="{Binding Index.SelectedIndexedLocation, Mode=TwoWay}"
                                             Style="{StaticResource NavListBoxStyle}"
                                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding Root}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:FontIcon Glyph="&#xE8B7;" FontSize="13" Margin="0,0,10,0"
                                                                 Foreground="{DynamicResource Atlas.AccentBrush}"
                                                                 VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                        <WrapPanel>
                                                            <Border Style="{StaticResource IndexStatusBadgeStyle}" Margin="0,3,4,3">
                                                                <TextBlock Text="{Binding RuntimeStatusSummary}"
                                                                           Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                                                            </Border>
                                                            <Border Style="{StaticResource WatchStatusBadgeStyle}" Margin="0,3,0,3">
                                                                <TextBlock Text="{Binding WatchSummary}"
                                                                           Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                                                            </Border>
                                                        </WrapPanel>
                                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedValueStyle}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Expander>

                            <Expander x:Name="SavedSection" Grid.Row="5"
                                      Header="SAVED SEARCHES" Style="{StaticResource NavSectionExpanderStyle}"
                                      Expanded="OnNavSectionToggled" Collapsed="OnNavSectionToggled">
                                <DockPanel>
                                    <Button DockPanel.Dock="Bottom"
                                            Command="{Binding History.ClearSavedSearchesCommand}"
                                            Style="{StaticResource NavItemButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,11,0"/>
                                            <TextBlock Text="Clear saved searches" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid DockPanel.Dock="Bottom"
                                          Margin="0,4,0,2"
                                          Visibility="{Binding History.SavedSearchList.IsFooterVisible, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding History.SavedSearchList.PreviousPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Previous page"
                                                Visibility="{Binding History.SavedSearchList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72B;" FontSize="11"/>
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding History.SavedSearchList.PageSummaryText}"
                                                   Style="{StaticResource SidebarPagerTextStyle}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding History.SavedSearchList.NextPageCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="24" Height="24"
                                                ToolTip="Next page"
                                                Visibility="{Binding History.SavedSearchList.IsPagerVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE72A;" FontSize="11"/>
                                        </Button>
                                    </Grid>

                                    <Grid DockPanel.Dock="Top">
                                        <TextBox Text="{Binding History.SavedSearchList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SidebarSearchBoxStyle}"
                                                 ui:ControlHelper.PlaceholderText="Search saved searches"/>
                                        <Button Command="{Binding History.SavedSearchList.ClearSearchCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="22" Height="22"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,2"
                                                ToolTip="Clear search"
                                                Visibility="{Binding History.SavedSearchList.HasSearchText, Converter={StaticResource BoolToVisibility}}">
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding History.SavedSearchList.Items}"
                                             SelectedItem="{Binding Search.SelectedSavedSearch, Mode=TwoWay}"
                                             Style="{StaticResource NavListBoxStyle}"
                                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding Summary}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Atlas.AccentBrush}"
                                                             Margin="1,0,12,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Summary}"
                                                                   Style="{StaticResource MutedValueStyle}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.History.RemoveSavedSearchCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Width="24" Height="24"
                                                            Margin="4,0,0,0"
                                                            ToolTip="Remove saved search">
                                                        <ui:FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Expander>
                    </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== Main column: omni + filters + results ===== -->
            <Grid Grid.Column="1" Margin="14,14,8,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Omni bar -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding Search.BrowseCommand}"
                            Style="{StaticResource IconButtonStyle}" ToolTip="Choose folder" Margin="0,0,8,0">
                        <ui:FontIcon Glyph="&#xE8B7;" FontSize="15"/>
                    </Button>

                    <Border Grid.Column="1" Style="{StaticResource OmniBarStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>
                            <ui:FontIcon Glyph="&#xE721;" FontSize="15" Margin="0,0,10,0"
                                         Foreground="{DynamicResource Atlas.Ink3Brush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchPathBox"
                                     Grid.Column="1"
                                     Text="{Binding Search.SearchPath, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource OmniPathBoxStyle}"
                                     ui:ControlHelper.PlaceholderText="Folder to search"/>
                            <Border Grid.Column="2" Style="{StaticResource OmniDividerStyle}"/>
                            <TextBox x:Name="QueryBox"
                                     Grid.Column="3"
                                     Text="{Binding Search.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource OmniQueryBoxStyle}"
                                     ui:ControlHelper.PlaceholderText="Search text, regex, or Boolean query"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Command="{Binding Search.SearchCommand}" IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE768;" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Start"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Command="{Binding Search.CancelCommand}" IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Command="{Binding Search.TogglePreviewPaneCommand}"
                            Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0"
                            ToolTip="Show or hide the preview pane">
                        <ui:FontIcon Glyph="&#xE8A1;" FontSize="15"/>
                    </Button>
                </Grid>

                <!-- Filter chips -->
                <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                    <Border Style="{StaticResource FilterChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pattern" Style="{StaticResource ChipLabelStyle}"/>
                            <TextBox Text="{Binding Search.FileNamePattern, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="260" MaxWidth="460" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Glob patterns separated by ; or , — e.g. *.cs;*.md"
                                     ui:ControlHelper.PlaceholderText="All files (e.g. *.cs;*.md)"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Exclude" Style="{StaticResource ChipLabelStyle}"/>
                            <TextBox Text="{Binding Search.ExcludeFileNamePattern, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="220" MaxWidth="420" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Exclude glob patterns separated by ; or , — e.g. *.log;*.tmp"
                                     ui:ControlHelper.PlaceholderText="None (e.g. *.log;*.tmp)"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Mode" Style="{StaticResource ChipLabelStyle}"/>
                            <ComboBox SelectedItem="{Binding Search.SearchMode}"
                                      ItemsSource="{Binding Search.AvailableModes}"
                                      MinWidth="104" BorderThickness="0" Background="Transparent"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <CheckBox Content="{Binding Search.SubfoldersSummary}" IsChecked="{Binding Search.IncludeSubfolders}" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <CheckBox Content="{Binding Search.MatchCaseSummary}" IsChecked="{Binding Search.MatchCase}" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <CheckBox Content="{Binding Search.DocumentExtractionSummary}" IsChecked="{Binding Search.EnableDocumentExtraction}" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <CheckBox Content="{Binding Search.IndexSummaryText}" IsChecked="{Binding Search.UseIndex}" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <TextBlock Text="{Binding Search.DateSummary}" Style="{StaticResource MutedValueStyle}"/>
                    </Border>
                    <Expander Header="Advanced" Style="{StaticResource AdvancedExpanderStyle}">
                        <Border Style="{StaticResource AdvancedFlyoutCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="1.35*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="FILE SIZE (KB)" Style="{StaticResource SectionHeaderStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Min" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Search.MinSizeKB}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Max" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Search.MaxSizeKB}" ToolTip="0 = no upper limit"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MODIFIED" Style="{StaticResource SectionHeaderStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <CheckBox Content="After" IsChecked="{Binding Search.ModifiedAfterEnabled}"/>
                                            <DatePicker SelectedDate="{Binding Search.ModifiedAfter}"
                                                        IsEnabled="{Binding Search.ModifiedAfterEnabled}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <CheckBox Content="Before" IsChecked="{Binding Search.ModifiedBeforeEnabled}"/>
                                            <DatePicker SelectedDate="{Binding Search.ModifiedBefore}"
                                                        IsEnabled="{Binding Search.ModifiedBeforeEnabled}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="FILE TYPES" Style="{StaticResource SectionHeaderStyle}"/>
                                    <CheckBox Content="{Binding Search.UnknownFileTypesSummary}"
                                              IsChecked="{Binding Search.SkipUnknownFileTypes}"
                                              ToolTip="Faster, but extensionless or uncommon text files are not searched."/>
                                    <TextBlock Text="Additional plain-text extensions"
                                               Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,4"/>
                                    <TextBox Text="{Binding Search.AdditionalPlainTextExtensions, UpdateSourceTrigger=PropertyChanged}"
                                             ui:ControlHelper.PlaceholderText=".liquid; .tmpl; .foo"/>
                                    <TextBlock Text="Separate extensions with commas or semicolons."
                                               Style="{StaticResource HintLabelStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Expander>
                </WrapPanel>

                <!-- Results -->
                <Border Grid.Row="2" Style="{StaticResource ResultsSurfaceStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Context header -->
                        <StackPanel Grid.Row="0" Margin="2,0,2,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Search.ResultsContextText}" Style="{StaticResource CtxTitleStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Search.ResultsSummaryText}"
                                           Style="{StaticResource MutedValueStyle}" Margin="12,3,0,0"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,5"
                                        Margin="0,0,8,0"
                                        Click="OnExportMenuButtonClick"
                                        ToolTip="Export visible results">
                                    <Button.ContextMenu>
                                        <ContextMenu Placement="Bottom"
                                                     DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="CSV" Command="{Binding Search.ExportResultsCommand}" CommandParameter="csv"/>
                                            <MenuItem Header="JSON" Command="{Binding Search.ExportResultsCommand}" CommandParameter="json"/>
                                            <MenuItem Header="JSON Lines" Command="{Binding Search.ExportResultsCommand}" CommandParameter="jsonl"/>
                                            <MenuItem Header="Markdown" Command="{Binding Search.ExportResultsCommand}" CommandParameter="markdown"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Glyph="&#xEDE1;" FontSize="12" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export"/>
                                        <ui:FontIcon Glyph="&#xE70D;" FontSize="9" Margin="6,2,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Grid Grid.Column="4" Width="210">
                                    <TextBox Text="{Binding Search.RefinementQuery, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                             ui:ControlHelper.PlaceholderText="Filter results"
                                             Padding="8,4,28,4"/>
                                    <Button Command="{Binding Search.ClearRefinementCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="24" Height="24" HorizontalAlignment="Right" Margin="0,0,3,0"
                                            ToolTip="Clear filter">
                                        <ui:FontIcon Glyph="&#xE711;" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </Grid>

                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Sort" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.ResultSortOptions}"
                                                  SelectedItem="{Binding Search.SelectedSortOption}"
                                                  DisplayMemberPath="Label"
                                                  MinWidth="120" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Group" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.ResultGroupOptions}"
                                                  SelectedItem="{Binding Search.SelectedGroupOption}"
                                                  DisplayMemberPath="Label"
                                                  MinWidth="120" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Type" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.FileTypeFacetOptions}"
                                                  SelectedItem="{Binding Search.SelectedFileTypeFacet}"
                                                  DisplayMemberPath="DisplayText"
                                                  MinWidth="130" MaxWidth="180" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Folder" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.FolderFacetOptions}"
                                                  SelectedItem="{Binding Search.SelectedFolderFacet}"
                                                  DisplayMemberPath="DisplayText"
                                                  MinWidth="150" MaxWidth="260" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Date" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.ModifiedFacetOptions}"
                                                  SelectedItem="{Binding Search.SelectedModifiedFacet}"
                                                  DisplayMemberPath="DisplayText"
                                                  MinWidth="130" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Source" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.SourceFacetOptions}"
                                                  SelectedItem="{Binding Search.SelectedSourceFacet}"
                                                  DisplayMemberPath="DisplayText"
                                                  MinWidth="130" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FilterChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Size" Style="{StaticResource ChipLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Search.SizeFacetOptions}"
                                                  SelectedItem="{Binding Search.SelectedSizeFacet}"
                                                  DisplayMemberPath="DisplayText"
                                                  MinWidth="150" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>
                                <Button Command="{Binding Search.ClearResultFacetsCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="28" Height="28"
                                        ToolTip="Clear result facets">
                                    <ui:FontIcon Glyph="&#xE711;" FontSize="12"/>
                                </Button>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Result cards + empty state -->
                        <Grid Grid.Row="1">
                            <ListBox x:Name="ResultsList"
                                     ItemsSource="{Binding Search.FilesView}"
                                     SelectedItem="{Binding Search.SelectedFile}"
                                     Style="{StaticResource ResultsListStyle}"
                                     PreviewMouseMove="OnResultsPreviewMouseMove">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Margin="0,6,0,2"
                                                        Background="{DynamicResource Atlas.SurfaceBrush}"
                                                        BorderBrush="{DynamicResource Atlas.LineBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <TextBlock Style="{StaticResource SectionHeaderStyle}">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource ResultCardContainerStyle}">
                                        <EventSetter Event="MouseDoubleClick" Handler="OnResultCardDoubleClick"/>
                                        <Setter Property="Tag" Value="{Binding DataContext.Search, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGestureText="Enter">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8E5;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="_Reveal in Explorer" Command="{Binding RevealInExplorerCommand}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE838;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="_Rename..."
                                                              Command="{Binding PlacementTarget.Tag.RenameResultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8AC;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Move to _Recycle Bin"
                                                              Command="{Binding PlacementTarget.Tag.DeleteResultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE74D;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Copy file _path" Command="{Binding CopyPathCommand}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8C8;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy _folder path" Command="{Binding CopyFolderPathCommand}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8C8;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="{Binding PinActionText}"
                                                              Command="{Binding PlacementTarget.Tag.TogglePinResultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="{Binding PinGlyph}" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding FavoriteActionText}"
                                                              Command="{Binding PlacementTarget.Tag.ToggleFavoriteResultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="{Binding FavoriteGlyph}" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding ExcludeExtensionPatternMenuText}"
                                                              Command="{Binding PlacementTarget.Tag.ExcludeFileExtensionPatternCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}">
                                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE74D;" FontSize="14"/></MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FileResultViewModel}">
                                        <StackPanel>
                                            <!-- card head -->
                                            <Grid Margin="15,12,15,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource TypeBadgeStyle}"
                                                        Background="{Binding FileName, Converter={StaticResource TypeBrush}}">
                                                    <TextBlock Text="{Binding FileName, Converter={StaticResource TypeLabel}}"
                                                               Style="{StaticResource TypeBadgeTextStyle}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" Style="{StaticResource ResultNameStyle}"/>
                                                    <TextBlock Text="{Binding Directory}" Style="{StaticResource ResultPathStyle}"/>
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Command="{Binding DataContext.Search.ToggleFavoriteResultCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Margin="0,0,6,0"
                                                        ToolTip="{Binding FavoriteActionText}">
                                                    <ui:FontIcon Glyph="{Binding FavoriteGlyph}" FontSize="13"/>
                                                </Button>
                                                <Button Grid.Column="3"
                                                        Command="{Binding DataContext.Search.TogglePinResultCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{Binding PinActionText}">
                                                    <ui:FontIcon Glyph="{Binding PinGlyph}" FontSize="13"/>
                                                </Button>
                                                <Border Grid.Column="4" Style="{StaticResource HitsPillStyle}">
                                                    <TextBlock Style="{StaticResource HitsPillTextStyle}">
                                                        <Run Text="{Binding HitCount, Mode=OneWay}"/><Run Text=" hits"/>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- matching lines -->
                                            <Border Height="1" Background="{DynamicResource Atlas.LineBrush}"/>
                                            <ItemsControl ItemsSource="{Binding VisibleHits}" Margin="0,5,0,5">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3,12,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding LineNumber}" Style="{StaticResource LineNoStyle}"/>
                                                            <TextBlock Grid.Column="1" Style="{StaticResource LineTextStyle}"
                                                                       hl:HitHighlight.Hit="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- expand / collapse -->
                                            <Border Height="1" Background="{DynamicResource Atlas.LineBrush}"
                                                    Visibility="{Binding HasMoreHits, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Command="{Binding ToggleExpandCommand}"
                                                    Content="{Binding MoreText}"
                                                    Style="{StaticResource MoreLinkStyle}"
                                                    Visibility="{Binding HasMoreHits, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Search.Files.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:FontIcon Glyph="&#xE721;" FontSize="40" Opacity="0.22" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                <TextBlock Text="No results yet" Style="{StaticResource EmptyTitleStyle}"/>
                                <TextBlock Text="Enter a query and press Start. Matches appear here as cards, with the hit lines highlighted."
                                           Style="{StaticResource EmptyBodyStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== Splitter ===== -->
            <GridSplitter Grid.Column="2" Style="{StaticResource PreviewGridSplitterStyle}"
                          DragDelta="OnPreviewSplitterDragDelta"/>

            <!-- ===== Preview pane ===== -->
            <Border Grid.Column="3"
                    Visibility="{Binding Search.IsPreviewPaneVisible, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource PreviewPaneStyle}">
                <DockPanel>
                    <!-- header -->
                    <Border DockPanel.Dock="Top" Padding="16,14,14,12"
                            BorderBrush="{DynamicResource Atlas.LineBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PREVIEW" Style="{StaticResource UpperPanelLabelStyle}"/>
                            <Button Grid.Column="1"
                                    Command="{Binding Search.SelectedFile.RevealInExplorerCommand}"
                                    IsEnabled="{Binding Search.HasSelectedFile}"
                                    Style="{StaticResource IconButtonStyle}" Width="28" Height="28"
                                    ToolTip="Reveal in Explorer">
                                <ui:FontIcon Glyph="&#xE838;" FontSize="13"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- actions -->
                    <Grid DockPanel.Dock="Bottom" Margin="16,12,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding Search.SelectedFile.OpenCommand}" IsEnabled="{Binding Search.HasSelectedFile}"
                                Style="{StaticResource PreviewActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:FontIcon Glyph="&#xE8E5;" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Open"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding Search.SelectedFile.RevealInExplorerCommand}"
                                IsEnabled="{Binding Search.HasSelectedFile}"
                                Style="{StaticResource SecondaryPreviewActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:FontIcon Glyph="&#xE838;" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Reveal"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4"
                                IsEnabled="{Binding Search.HasSelectedFile}"
                                Style="{StaticResource SecondaryPreviewActionButtonStyle}"
                                Click="OnCopyMenuButtonClick"
                                ToolTip="Copy the path, the preview, or the full file content">
                            <Button.ContextMenu>
                                <ContextMenu Placement="Top"
                                             DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Copy file _path" Command="{Binding Search.SelectedFile.CopyPathCommand}">
                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8C8;" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Copy _preview" Command="{Binding Search.CopyPreviewCommand}">
                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE7C3;" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Copy file _content" Command="{Binding Search.CopyFileContentCommand}">
                                        <MenuItem.Icon><ui:FontIcon Glyph="&#xE8E5;" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:FontIcon Glyph="&#xE8C8;" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Copy"/>
                                <ui:FontIcon Glyph="&#xE70D;" FontSize="9" Margin="7,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- body -->
                    <Grid Margin="16,16,16,8">
                        <!-- selected file -->
                        <Grid Visibility="{Binding Search.HasSelectedFile, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                <Border Style="{StaticResource PreviewBadgeStyle}"
                                        Background="{Binding Search.SelectedFile.FileName, Converter={StaticResource TypeBrush}}">
                                    <TextBlock Text="{Binding Search.SelectedFile.FileName, Converter={StaticResource TypeLabel}}"
                                               Style="{StaticResource PreviewBadgeTextStyle}"/>
                                </Border>
                                <TextBlock Text="{Binding Search.SelectedFile.FileName}" Style="{StaticResource PreviewNameStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <Border BorderBrush="{DynamicResource Atlas.LineBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Location" Style="{StaticResource MetaKeyStyle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Search.SelectedFile.Directory}" Style="{StaticResource MetaValueStyle}" Margin="10,0,0,0"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Type" Style="{StaticResource MetaKeyStyle}"/>
                                            <TextBlock Grid.Column="1" Style="{StaticResource MetaValueStyle}" Margin="10,0,0,0">
                                                <Run Text="."/><Run Text="{Binding Search.SelectedFile.Extension, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Size" Style="{StaticResource MetaKeyStyle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Search.SelectedFile.SizeText}" Style="{StaticResource MetaValueStyle}" Margin="10,0,0,0"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Modified" Style="{StaticResource MetaKeyStyle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Search.SelectedFile.ModifiedText}" Style="{StaticResource MetaValueStyle}" Margin="10,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <TextBox Grid.Row="2" Text="{Binding Search.PreviewContent, Mode=OneWay}"
                                     Style="{StaticResource PreviewCodeBoxStyle}"/>
                        </Grid>

                        <!-- empty -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="240">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Search.SelectedFile}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:FontIcon Glyph="&#xE8A5;" FontSize="34" Opacity="0.22" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Select a result" Style="{StaticResource EmptyTitleStyle}"/>
                            <TextBlock Text="Matching lines and surrounding context appear here, with hits highlighted."
                                       Style="{StaticResource EmptyBodyStyle}"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
