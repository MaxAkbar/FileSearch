<Window x:Class="FileSearch.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FileSearch.Gui.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="FileSearch" Height="800" Width="1280"
        MinHeight="540" MinWidth="960">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Style="{StaticResource AppRootStyle}">
        <!-- ============ Menu ============ -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_Install Windows integration"
                          Command="{Binding InstallWindowsIntegrationCommand}"/>
                <MenuItem Header="_Remove Windows integration"
                          Command="{Binding RemoveWindowsIntegrationCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Search">
                <MenuItem Header="_Start" Command="{Binding SearchCommand}" InputGestureText="Enter"/>
                <MenuItem Header="_Cancel" Command="{Binding CancelCommand}" InputGestureText="Esc"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Theme">
                    <MenuItem Header="_Light"          Command="{Binding ApplyThemeCommand}" CommandParameter="Light"/>
                    <MenuItem Header="_Dark"           Command="{Binding ApplyThemeCommand}" CommandParameter="Dark"/>
                    <MenuItem Header="Visual _Studio" Command="{Binding ApplyThemeCommand}" CommandParameter="VisualStudio"/>
                    <Separator/>
                    <MenuItem Header="_System"         Command="{Binding ApplyThemeCommand}" CommandParameter="System"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_User guide" Click="OnHelpClick"/>
                <Separator/>
                <MenuItem Header="_About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- ============ Status bar ============ -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource StatusBarShellStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:FontIcon Glyph="&#xE946;" FontSize="12" Margin="0,0,8,0"
                             Opacity="0.6" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="2" Width="140" Height="3"
                             IsIndeterminate="{Binding IsSearching}"
                             Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}"
                             VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ============ Search form ============ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CommandBandStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Header row: title + actions -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <ui:FontIcon Glyph="&#xE721;" FontSize="18" Margin="0,0,10,0" Opacity="0.9"/>
                    <TextBlock Text="Find in files" Style="{StaticResource PageTitleStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,12">
                    <Button Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryCommandButtonStyle}"
                            IsDefault="True">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE768;" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Start"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryCommandButtonStyle}"
                            Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Tabbed form -->
                <TabControl Grid.Row="1" Grid.ColumnSpan="2" SelectedIndex="0"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource HeaderTabItemStyle}">
                    <!-- ====== Main tab ====== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8A5;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Main" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="0.85*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="1.25*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Primary query -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Containing text" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox Text="{Binding QueryText, UpdateSourceTrigger=LostFocus}"
                                              ItemsSource="{Binding RecentQueries}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnHistoryComboBoxSelectionChanged"
                                              PreviewKeyDown="OnHistoryComboBoxPreviewKeyDown"
                                              ui:ControlHelper.PlaceholderText="search expression">
                                        <ComboBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                                        </ComboBox.InputBindings>
                                    </ComboBox>
                                    <TextBlock Text="Press Enter to search or choose a recent query."
                                               Style="{StaticResource HintLabelStyle}"/>
                                </StackPanel>

                                <!-- File pattern -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="File name pattern" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding FileNamePattern, UpdateSourceTrigger=PropertyChanged}"
                                             ui:ControlHelper.PlaceholderText="*.cs;*.txt"/>
                                    <TextBlock Text="Use semicolons for multiple globs."
                                               Style="{StaticResource HintLabelStyle}"/>
                                </StackPanel>

                                <!-- Folder scope -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Look in" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Text="{Binding SearchPath, UpdateSourceTrigger=LostFocus}"
                                                  ItemsSource="{Binding RecentPaths}"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnHistoryComboBoxSelectionChanged"
                                                  PreviewKeyDown="OnHistoryComboBoxPreviewKeyDown"/>
                                        <Button Grid.Column="1" Command="{Binding BrowseCommand}"
                                                Margin="6,0,0,0" ToolTip="Browse folder…"
                                                Style="{StaticResource IconButtonStyle}">
                                            <ui:FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                                        </Button>
                                    </Grid>

                                    <CheckBox Content="Include subfolders"
                                              IsChecked="{Binding IncludeSubfolders}"
                                              Margin="0,14,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </TabItem>

                    <!-- ====== Options tab ====== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE713;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Options" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="QUERY" Style="{StaticResource SectionHeaderStyle}"/>
                                    <TextBlock Text="Search mode" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox SelectedItem="{Binding SearchMode}"
                                              ItemsSource="{Binding AvailableModes}"
                                              HorizontalAlignment="Stretch"/>
                                    <CheckBox Content="Match case" IsChecked="{Binding MatchCase}" Margin="0,14,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="DOCUMENT EXTRACTION" Style="{StaticResource SectionHeaderStyle}"/>
                                    <CheckBox Content="Office &amp; PDF documents"
                                              IsChecked="{Binding EnableDocumentExtraction}"
                                              ToolTip="When off, .pdf, .docx, .xlsx are skipped entirely."/>
                                    <TextBlock Text="Skips .pdf, .docx, .xlsx when off"
                                               Style="{StaticResource HintLabelStyle}"/>
                                    <CheckBox Content="Skip unknown file types"
                                              IsChecked="{Binding SkipUnknownFileTypes}"
                                              Margin="0,14,0,0"
                                              ToolTip="Faster, but extensionless or uncommon text files are not searched."/>
                                    <TextBlock Text="Off by default to preserve full text coverage"
                                               Style="{StaticResource HintLabelStyle}"/>
                                    <TextBlock Text="Additional plain-text extensions" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,0"/>
                                    <TextBox Text="{Binding AdditionalPlainTextExtensions, UpdateSourceTrigger=PropertyChanged}"
                                             ui:ControlHelper.PlaceholderText=".liquid; .tmpl; .foo"/>
                                    <TextBlock Text="Used when skipping unknown file types. Separate with commas or semicolons."
                                               Style="{StaticResource HintLabelStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="FILE SIZE (KB)" Style="{StaticResource SectionHeaderStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Min" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding MinSizeKB}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Max" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding MaxSizeKB}" ToolTip="0 = no upper limit"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </TabItem>

                    <!-- ====== Dates tab ====== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE787;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Dates" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="MODIFIED" Style="{StaticResource SectionHeaderStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <CheckBox Content="After" IsChecked="{Binding ModifiedAfterEnabled}"/>
                                        <DatePicker SelectedDate="{Binding ModifiedAfter}"
                                                    IsEnabled="{Binding ModifiedAfterEnabled}"
                                                    Margin="0,6,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <CheckBox Content="Before" IsChecked="{Binding ModifiedBeforeEnabled}"/>
                                        <DatePicker SelectedDate="{Binding ModifiedBefore}"
                                                    IsEnabled="{Binding ModifiedBeforeEnabled}"
                                                    Margin="0,6,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- ============ Main split: results | side panel ============ -->
        <Grid Margin="20,18,20,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="420"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="5*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Results card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <!-- Header strip -->
                    <Grid VerticalAlignment="Top" Margin="18,14,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:FontIcon Glyph="&#xE8B7;" FontSize="14" Margin="0,0,8,0" Opacity="0.75"/>
                        <TextBlock Grid.Column="1" Text="Files" Style="{StaticResource PanelTitleStyle}"/>
                        <Border Grid.Column="2" Style="{StaticResource HitPillStyle}" MinWidth="42">
                            <TextBlock Text="{Binding FilesMatched}" Style="{StaticResource HitPillTextStyle}"/>
                        </Border>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid Margin="0,48,0,0"
                              Style="{StaticResource ResultsDataGridStyle}"
                              ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserSortColumns="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ResultsDataGridRowStyle}">
                                <EventSetter Event="MouseDoubleClick" Handler="OnResultRowDoubleClick"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGestureText="Enter">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="_Reveal in Explorer" Command="{Binding RevealInExplorerCommand}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE838;" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem Header="Copy file _path" Command="{Binding CopyPathCommand}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Copy _folder path" Command="{Binding CopyFolderPathCommand}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FileName}" Width="1.35*" MinWidth="160"/>
                            <DataGridTemplateColumn Header="Hits" Width="72" SortMemberPath="HitCount">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ResultsDataGridColumnHeaderStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource HitPillStyle}">
                                            <TextBlock Text="{Binding HitCount}" Style="{StaticResource HitPillTextStyle}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="First match" Binding="{Binding FirstMatch}" Width="1.6*" MinWidth="180"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Directory}" Width="2*" MinWidth="220"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state overlay -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,48,0,0" MaxWidth="320" TextBlock.TextAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:FontIcon Glyph="&#xE721;" FontSize="48" Opacity="0.25"/>
                        <TextBlock Text="No results yet" FontSize="18" FontWeight="SemiBold"
                                   Margin="0,16,0,4" Opacity="0.85"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6"
                                   Text="Enter a folder and a search expression, then press Start (or hit Enter)."/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

            <!-- Side panel: Summary / Hits / Reports -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18,12,18,18">
                <TabControl SelectedIndex="{Binding SelectedDetailsTabIndex, Mode=TwoWay}"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource HeaderTabItemStyle}">
                    <!-- ===== Summary ===== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE9D9;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Summary" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Search statistics" Style="{StaticResource PanelTitleStyle}"
                                       Margin="0,0,0,14" Opacity="0.9"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Files matched" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="{Binding FilesMatched}" Style="{StaticResource StatValueStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="4,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="Total hits" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="{Binding TotalHits}" Style="{StaticResource StatValueStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Elapsed" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource StatValueStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ===== Hits / Preview ===== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8A5;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Hits" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- File header card -->
                            <Border Grid.Row="0" Padding="0,0,0,12"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,0,1"
                                    Visibility="{Binding HasSelectedFile, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ui:FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="22"
                                                 Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedFile.FileName}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SelectedFile.Directory}"
                                                   Style="{StaticResource HintLabelStyle}"
                                                   TextTrimming="CharacterEllipsis" Margin="0"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource HitPillStyle}">
                                        <TextBlock Text="{Binding SelectedFile.HitCount}" Style="{StaticResource HitPillTextStyle}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Preview content -->
                            <TextBox Grid.Row="1"
                                     Text="{Binding PreviewContent, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Cascadia Code, Consolas, Courier New"
                                     FontSize="12.5"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     BorderThickness="0"
                                     Padding="0,12,0,0"
                                     Background="Transparent"/>

                            <!-- Empty state -->
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        MaxWidth="280" TextBlock.TextAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:FontIcon Glyph="&#xE8A5;" FontSize="40" Opacity="0.25"/>
                                <TextBlock Text="Select a file" FontSize="16" FontWeight="SemiBold"
                                           Margin="0,12,0,4" Opacity="0.85"/>
                                <TextBlock Text="Pick a row on the left to see its matching lines with context."
                                           TextWrapping="Wrap" Opacity="0.6"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- ===== Filter results ("search the search") ===== -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE71C;" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Filter" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Filter results" FontSize="14" FontWeight="SemiBold"
                                       Margin="0,0,0,4" Opacity="0.85"/>
                            <TextBlock Grid.Row="1" Style="{StaticResource HintLabelStyle}"
                                       Margin="0,0,0,16"
                                       Text="Narrows the file list to entries whose name or any hit line contains this text."/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding RefinementQuery, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                                         ui:ControlHelper.PlaceholderText="Type to filter…"/>
                                <Button Grid.Column="1" Margin="6,0,0,0"
                                        Command="{Binding ClearRefinementCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Clear filter">
                                    <ui:FontIcon Glyph="&#xE711;" FontSize="13"/>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Opacity="0.75" FontSize="12">
                                <Run Text="Showing"/>
                                <Run Text="{Binding FilesVisible, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="of"/>
                                <Run Text="{Binding FilesMatched, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="files."/>
                            </TextBlock>

                            <TextBlock Grid.Row="4" VerticalAlignment="Top" Margin="0,20,0,0"
                                       Opacity="0.55" FontSize="11" TextWrapping="Wrap"
                                       Text="This is an in-memory filter — it doesn't re-scan files, so it's instant. Clear the field to see all results again."/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
