<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Visual Studio Dark palette.

        Applied as an overlay on top of ModernWpf's Dark theme. It overrides
        the ModernWpf SystemControl* keys (for built-in controls) and the
        Atlas.* keys (for our own surfaces) with a VS-inspired blue/grey
        palette. Removing this overlay restores the Atlas Light defaults from
        AppStyles.xaml.
    -->

    <!-- Palette -->
    <Color x:Key="VsWindowColor">#FF18191B</Color>
    <Color x:Key="VsPanelColor">#FF202124</Color>
    <Color x:Key="VsListAltColor">#FF282A2E</Color>
    <Color x:Key="VsHoverColor">#FF30333A</Color>
    <Color x:Key="VsSelectionColor">#FF0B4F79</Color>
    <Color x:Key="VsBorderColor">#FF3A3D42</Color>
    <Color x:Key="VsAccentColor">#FF0E8DDA</Color>
    <Color x:Key="VsAccentHoverColor">#FF32A4F0</Color>
    <Color x:Key="Atlas.AccentColor">#FF0E8DDA</Color>
    <Color x:Key="Atlas.Accent2Color">#FF32A4F0</Color>
    <Color x:Key="Atlas.PaperColor">#FF18191B</Color>
    <Color x:Key="Atlas.SurfaceColor">#FF202124</Color>
    <Color x:Key="Atlas.Surface2Color">#FF282A2E</Color>
    <Color x:Key="Atlas.SidebarColor">#FF1C1D20</Color>
    <Color x:Key="Atlas.InkColor">#FFF4F4F5</Color>
    <Color x:Key="Atlas.Ink2Color">#FFC9CBD1</Color>
    <Color x:Key="Atlas.Ink3Color">#FF8F949E</Color>
    <Color x:Key="Atlas.LineColor">#1FFFFFFF</Color>
    <Color x:Key="Atlas.Line2Color">#FF3A3D42</Color>
    <Color x:Key="Atlas.HoverColor">#14FFFFFF</Color>
    <Color x:Key="Atlas.SelColor">#FF0B4F79</Color>
    <Color x:Key="Atlas.AccentTintColor">#330E8DDA</Color>
    <Color x:Key="Atlas.AccentSoftColor">#220E8DDA</Color>
    <Color x:Key="Atlas.OnAccentColor">#FFFFFFFF</Color>
    <Color x:Key="Atlas.WarmColor">#FFD98A45</Color>
    <Color x:Key="Atlas.WarmTintColor">#33D98A45</Color>
    <Color x:Key="Atlas.HitColor">#99FFCE54</Color>
    <Color x:Key="Atlas.HitInkColor">#FF18191B</Color>
    <SolidColorBrush x:Key="AppStyle.OmniBarBackground" Color="#FF252526"/>
    <SolidColorBrush x:Key="AppStyle.FilterChipBackground" Color="#FF252526"/>
    <SolidColorBrush x:Key="AppStyle.ThemeMiniButtonSelectedBackground" Color="#330E8DDA"/>
    <SolidColorBrush x:Key="AppStyle.ThemeMiniButtonSelectedBorderBrush" Color="#FF0E8DDA"/>
    <SolidColorBrush x:Key="AppStyle.ThemeMiniButtonSelectedForeground" Color="#FFF4F4F5"/>
    <SolidColorBrush x:Key="AppStyle.QueryChipBackground" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="AppStyle.NavSectionBackground" Color="#FF252526"/>
    <SolidColorBrush x:Key="AppStyle.NavSectionHeaderBackground" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="AppStyle.NavSectionHeaderBorderBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="AppStyle.PreviewImageBackground" Color="#FF2D2D30"/>
    <CornerRadius x:Key="AppStyle.CommandButtonCornerRadius">9</CornerRadius>
    <SolidColorBrush x:Key="AppStyle.SecondaryButtonBackground" Color="#FF252526"/>
    <SolidColorBrush x:Key="AppStyle.SecondaryButtonBorderBrush" Color="#FF3A3D42"/>
    <SolidColorBrush x:Key="AppStyle.SecondaryButtonHoverBackground" Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="AppStyle.SecondaryButtonHoverBorderBrush" Color="#FF0E8DDA"/>
    <SolidColorBrush x:Key="AppStyle.SecondaryButtonHoverForeground" Color="#FFF4F4F5"/>
    <SolidColorBrush x:Key="AppStyle.IconButtonHoverBackground" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="AppStyle.IconButtonHoverForeground" Color="#FFF4F4F5"/>
    <SolidColorBrush x:Key="AppStyle.PreviewCodeBackground" Color="#FF252526"/>
    <Color x:Key="VsTextColor">#FFF4F4F5</Color>
    <Color x:Key="VsTextSecondaryColor">#FFC9CBD1</Color>
    <Color x:Key="VsTextMutedColor">#FF8F949E</Color>

    <!-- ===== Our surfaces (Atlas.*) ===== -->
    <SolidColorBrush x:Key="Atlas.PaperBrush"      Color="{StaticResource VsWindowColor}"/>
    <SolidColorBrush x:Key="Atlas.SurfaceBrush"    Color="{StaticResource VsPanelColor}"/>
    <SolidColorBrush x:Key="Atlas.Surface2Brush"   Color="{StaticResource VsListAltColor}"/>
    <SolidColorBrush x:Key="Atlas.SidebarBrush"    Color="#FF1C1D20"/>
    <SolidColorBrush x:Key="Atlas.InkBrush"        Color="{StaticResource VsTextColor}"/>
    <SolidColorBrush x:Key="Atlas.Ink2Brush"       Color="{StaticResource VsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="Atlas.Ink3Brush"       Color="{StaticResource VsTextMutedColor}"/>
    <SolidColorBrush x:Key="Atlas.LineBrush"       Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="Atlas.Line2Brush"      Color="{StaticResource VsBorderColor}"/>
    <SolidColorBrush x:Key="Atlas.HoverBrush"      Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="Atlas.SelBrush"        Color="{StaticResource VsSelectionColor}"/>
    <SolidColorBrush x:Key="Atlas.AccentBrush"     Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="Atlas.Accent2Brush"    Color="{StaticResource VsAccentHoverColor}"/>
    <SolidColorBrush x:Key="Atlas.AccentTintBrush" Color="#330E8DDA"/>
    <SolidColorBrush x:Key="Atlas.AccentSoftBrush" Color="#220E8DDA"/>
    <SolidColorBrush x:Key="Atlas.OnAccentBrush"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="Atlas.WarmBrush"       Color="#FFD98A45"/>
    <SolidColorBrush x:Key="Atlas.WarmTintBrush"   Color="#33D98A45"/>
    <SolidColorBrush x:Key="Atlas.HitBrush"        Color="#99FFCE54"/>
    <SolidColorBrush x:Key="Atlas.HitInkBrush"     Color="{StaticResource VsWindowColor}"/>

    <!-- ===== Built-in controls (ModernWpf SystemControl*) ===== -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource VsWindowColor}"/>

    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush" Color="{StaticResource VsPanelColor}"/>
    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush"    Color="{StaticResource VsPanelColor}"/>
    <SolidColorBrush x:Key="SystemControlBackgroundChromeHighBrush"      Color="{StaticResource VsPanelColor}"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAltMediumLowBrush"    Color="{StaticResource VsWindowColor}"/>
    <SolidColorBrush x:Key="SystemControlBackgroundAltMediumBrush"       Color="{StaticResource VsListAltColor}"/>

    <SolidColorBrush x:Key="SystemControlBackgroundListLowBrush"    Color="{StaticResource VsListAltColor}"/>
    <SolidColorBrush x:Key="SystemControlBackgroundListMediumBrush" Color="{StaticResource VsHoverColor}"/>

    <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush"      Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush"       Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="SystemControlHighlightAltAccentBrush"    Color="{StaticResource VsAccentHoverColor}"/>
    <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="{StaticResource VsSelectionColor}"/>

    <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush"     Color="{StaticResource VsTextColor}"/>
    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush"   Color="{StaticResource VsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="SystemControlForegroundBaseMediumHighBrush" Color="{StaticResource VsTextColor}"/>
    <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush"      Color="{StaticResource VsBorderColor}"/>
    <SolidColorBrush x:Key="SystemControlForegroundChromeWhiteBrush"  Color="#FFFFFFFF"/>

    <!-- Accent color resources (some ModernWpf controls bind to these directly) -->
    <Color           x:Key="SystemAccentColor">#FF007ACC</Color>
    <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource VsAccentColor}"/>

</ResourceDictionary>
