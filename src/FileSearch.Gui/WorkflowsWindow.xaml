<Window x:Class="FileSearch.Gui.WorkflowsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FileSearch.Gui.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="Workflows"
        Height="800"
        Width="1240"
        MinHeight="660"
        MinWidth="1080"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Compact rows for the log / hits / roots lists. -->
        <Style x:Key="CompactListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="StepListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource NavListBoxItemStyle}">
            <Setter Property="ToolTip" Value="{Binding Summary}"/>
        </Style>

        <Style x:Key="LibraryListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource NavListBoxItemStyle}">
            <Setter Property="ToolTip" Value="{Binding FileName}"/>
        </Style>

        <Style x:Key="WfLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <Style x:Key="WfBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- ===== Condition editor (if-branches and retry exits) ===== -->
        <DataTemplate DataType="{x:Type vm:WorkflowConditionViewModel}">
            <StackPanel>
                <TextBlock Text="Measure results of" Style="{StaticResource WfLabelStyle}" Margin="0,0,0,4"/>
                <ComboBox IsEditable="True"
                          Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.SourceStepOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox SelectedItem="{Binding Metric}"
                              ItemsSource="{x:Static vm:WorkflowEnumValues.ConditionMetrics}"/>
                    <ComboBox Grid.Column="2"
                              SelectedItem="{Binding Operator}"
                              ItemsSource="{x:Static vm:WorkflowEnumValues.ConditionOperators}"/>
                    <TextBox Grid.Column="4" Text="{Binding Value}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- ===== Per-step property panels ===== -->
        <DataTemplate DataType="{x:Type vm:SearchStepViewModel}">
            <StackPanel>
                <TextBlock Text="Query" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="Search text, regex, or Boolean query — supports ${variable}"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox SelectedItem="{Binding Mode}"
                              ItemsSource="{x:Static vm:WorkflowEnumValues.QueryModes}"/>
                    <CheckBox Grid.Column="2" Content="Match case" IsChecked="{Binding CaseSensitive}"/>
                    <CheckBox Grid.Column="4" Content="Use index" IsChecked="{Binding UseIndex}"
                              IsEnabled="{Binding IsFileSystemScope}"
                              ToolTip="Prefer the local index when coverage allows (filesystem searches only)."/>
                </Grid>

                <TextBlock Text="Scope" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox IsEditable="True"
                          Text="{Binding ScopeStepId, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.ScopeStepOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                          ToolTip="Search only the files matched by an earlier search step instead of walking folders."/>

                <TextBlock Text="Root folders" Style="{StaticResource WfLabelStyle}"/>
                <ListBox ItemsSource="{Binding Roots}"
                         SelectedItem="{Binding SelectedRoot, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource CompactListItemStyle}"
                         Height="78"
                         FontFamily="{DynamicResource Atlas.MonoFont}"
                         FontSize="12"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding NewRoot, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="Folder path — supports ${variable}"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Add" Command="{Binding AddRootCommand}"
                            Style="{StaticResource ToolButtonStyle}"/>
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseRootCommand}"
                            Style="{StaticResource ToolButtonStyle}"/>
                    <Button Grid.Column="3" Content="Remove" Command="{Binding RemoveRootCommand}"
                            Style="{StaticResource ToolButtonStyle}" Margin="0"/>
                </Grid>
                <TextBlock Text="Roots are ignored when a scope step is selected."
                           Style="{StaticResource HintLabelStyle}"/>

                <!-- The runner only applies the filters to filesystem walks;
                     a search scoped to a previous step's results disables them. -->
                <StackPanel IsEnabled="{Binding IsFileSystemScope}">
                    <TextBlock Text="Include globs" Style="{StaticResource WfLabelStyle}"/>
                    <TextBox Text="{Binding IncludeGlobs, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="*.cs; *.md (empty = all files)"/>
                    <TextBlock Text="Exclude globs" Style="{StaticResource WfLabelStyle}"/>
                    <TextBox Text="{Binding ExcludeGlobs, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="*.min.js; *.designer.cs (file names only)"/>

                    <TextBlock Text="Excluded folders" Style="{StaticResource WfLabelStyle}"/>
                    <CheckBox Content="Use default exclusions (.git, .vs, node_modules)"
                              IsChecked="{Binding UseDefaultExcludedFolders}"/>
                    <TextBox Text="{Binding ExcludeDirectories, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CustomExcludedFoldersEnabled}"
                             Margin="0,4,0,0"
                             ui:ControlHelper.PlaceholderText="bin; obj; .git (empty = walk everything)"/>
                    <TextBlock Text="Folder names are skipped with their whole subtree. A custom list replaces the defaults."
                               Style="{StaticResource HintLabelStyle}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox Content="Include subfolders" IsChecked="{Binding Recursive}" Margin="0,0,16,0"/>
                        <CheckBox Content="Include hidden files" IsChecked="{Binding IncludeHidden}"/>
                    </StackPanel>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Min size (bytes)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding MinFileSizeBytes}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max size (bytes)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding MaxFileSizeBytes}" ToolTip="0 disables the size cap."/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <CheckBox Content="Modified after" IsChecked="{Binding ModifiedAfterEnabled}"/>
                            <DatePicker SelectedDate="{Binding ModifiedAfter}"
                                        IsEnabled="{Binding ModifiedAfterEnabled}"
                                        Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <CheckBox Content="Modified before" IsChecked="{Binding ModifiedBeforeEnabled}"/>
                            <DatePicker SelectedDate="{Binding ModifiedBefore}"
                                        IsEnabled="{Binding ModifiedBeforeEnabled}"
                                        Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
                <TextBlock Text="Filters are ignored when a scope step is selected."
                           Style="{StaticResource HintLabelStyle}"/>

                <TextBlock Text="Max hits" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding MaxHits}" Width="120" HorizontalAlignment="Left"
                         ToolTip="Stop the search after this many hits; 0 means unlimited."/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:IfStepViewModel}">
            <StackPanel>
                <TextBlock Text="Condition" Style="{StaticResource WfLabelStyle}"/>
                <ContentControl Content="{Binding Condition}" Focusable="False"/>

                <TextBlock Text="Branches" Style="{StaticResource WfLabelStyle}"/>
                <StackPanel Orientation="Horizontal">
                    <Button Click="OnAddMenuClick" Style="{StaticResource ToolButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Add step to Then"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Search" Command="{Binding AddThenStepCommand}" CommandParameter="search"/>
                                <MenuItem Header="If (condition)" Command="{Binding AddThenStepCommand}" CommandParameter="if"/>
                                <MenuItem Header="Retry loop" Command="{Binding AddThenStepCommand}" CommandParameter="retry"/>
                                <MenuItem Header="For each file" Command="{Binding AddThenStepCommand}" CommandParameter="forEach"/>
                                <MenuItem Header="Export results" Command="{Binding AddThenStepCommand}" CommandParameter="export"/>
                                <MenuItem Header="Copy / move files" Command="{Binding AddThenStepCommand}" CommandParameter="fileOperation"/>
                                <MenuItem Header="Run program" Command="{Binding AddThenStepCommand}" CommandParameter="runProgram"/>
                                <MenuItem Header="Stop" Command="{Binding AddThenStepCommand}" CommandParameter="stop"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Click="OnAddMenuClick" Style="{StaticResource ToolButtonStyle}" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Add step to Else"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Search" Command="{Binding AddElseStepCommand}" CommandParameter="search"/>
                                <MenuItem Header="If (condition)" Command="{Binding AddElseStepCommand}" CommandParameter="if"/>
                                <MenuItem Header="Retry loop" Command="{Binding AddElseStepCommand}" CommandParameter="retry"/>
                                <MenuItem Header="For each file" Command="{Binding AddElseStepCommand}" CommandParameter="forEach"/>
                                <MenuItem Header="Export results" Command="{Binding AddElseStepCommand}" CommandParameter="export"/>
                                <MenuItem Header="Copy / move files" Command="{Binding AddElseStepCommand}" CommandParameter="fileOperation"/>
                                <MenuItem Header="Run program" Command="{Binding AddElseStepCommand}" CommandParameter="runProgram"/>
                                <MenuItem Header="Stop" Command="{Binding AddElseStepCommand}" CommandParameter="stop"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
                <TextBlock Text="Branch steps appear indented under this step in the list, tagged 'then' or 'else'."
                           Style="{StaticResource HintLabelStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RetryStepViewModel}">
            <StackPanel>
                <TextBlock Text="Repeat until" Style="{StaticResource WfLabelStyle}"/>
                <ContentControl Content="{Binding Until}" Focusable="False"/>

                <TextBlock Text="Max iterations" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding MaxIterations}" Width="120" HorizontalAlignment="Left"/>

                <TextBlock Text="Loop body" Style="{StaticResource WfLabelStyle}"/>
                <Button Click="OnAddMenuClick" Style="{StaticResource ToolButtonStyle}" HorizontalAlignment="Left" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Add step to body"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Search" Command="{Binding AddBodyStepCommand}" CommandParameter="search"/>
                            <MenuItem Header="If (condition)" Command="{Binding AddBodyStepCommand}" CommandParameter="if"/>
                            <MenuItem Header="Retry loop" Command="{Binding AddBodyStepCommand}" CommandParameter="retry"/>
                            <MenuItem Header="For each file" Command="{Binding AddBodyStepCommand}" CommandParameter="forEach"/>
                            <MenuItem Header="Export results" Command="{Binding AddBodyStepCommand}" CommandParameter="export"/>
                            <MenuItem Header="Copy / move files" Command="{Binding AddBodyStepCommand}" CommandParameter="fileOperation"/>
                            <MenuItem Header="Run program" Command="{Binding AddBodyStepCommand}" CommandParameter="runProgram"/>
                            <MenuItem Header="Stop" Command="{Binding AddBodyStepCommand}" CommandParameter="stop"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <TextBlock Text="The body sees ${iteration} (1-based) plus the keys of the matching parameter set."
                           Style="{StaticResource HintLabelStyle}"/>

                <TextBlock Text="Parameter sets (one per iteration)" Style="{StaticResource WfLabelStyle}"/>
                <ItemsControl ItemsSource="{Binding ParameterSets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="56"
                                         FontFamily="{DynamicResource Atlas.MonoFont}"
                                         FontSize="12"
                                         ui:ControlHelper.PlaceholderText="key=value (one per line)"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Top"
                                        ToolTip="Remove this parameter set"
                                        Command="{Binding DataContext.RemoveParameterSetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <ui:FontIcon Glyph="&#xE74D;" FontSize="13"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Command="{Binding AddParameterSetCommand}"
                        Style="{StaticResource ToolButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Add parameter set"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ForEachStepViewModel}">
            <StackPanel>
                <TextBlock Text="Files from" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox IsEditable="True"
                          Text="{Binding SourceStepId, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.SourceStepOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="Max files" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding MaxItems}" Width="120" HorizontalAlignment="Left"
                         ToolTip="Safety cap on iterated files; 0 means unlimited."/>

                <TextBlock Text="Loop body" Style="{StaticResource WfLabelStyle}"/>
                <Button Click="OnAddMenuClick" Style="{StaticResource ToolButtonStyle}" HorizontalAlignment="Left" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Add step to body"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Search" Command="{Binding AddBodyStepCommand}" CommandParameter="search"/>
                            <MenuItem Header="If (condition)" Command="{Binding AddBodyStepCommand}" CommandParameter="if"/>
                            <MenuItem Header="Retry loop" Command="{Binding AddBodyStepCommand}" CommandParameter="retry"/>
                            <MenuItem Header="For each file" Command="{Binding AddBodyStepCommand}" CommandParameter="forEach"/>
                            <MenuItem Header="Export results" Command="{Binding AddBodyStepCommand}" CommandParameter="export"/>
                            <MenuItem Header="Copy / move files" Command="{Binding AddBodyStepCommand}" CommandParameter="fileOperation"/>
                            <MenuItem Header="Run program" Command="{Binding AddBodyStepCommand}" CommandParameter="runProgram"/>
                            <MenuItem Header="Stop" Command="{Binding AddBodyStepCommand}" CommandParameter="stop"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <TextBlock Text="The body sees ${file}, ${fileName} and ${directory} for the current file."
                           Style="{StaticResource HintLabelStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ExportStepViewModel}">
            <StackPanel>
                <TextBlock Text="Results to export" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox IsEditable="True"
                          Text="{Binding SourceStepId, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.ExportSourceOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="Format" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox SelectedItem="{Binding Format}"
                          ItemsSource="{x:Static vm:WorkflowEnumValues.ExportFormats}"
                          Width="160" HorizontalAlignment="Left"/>

                <TextBlock Text="Output file" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="C:\reports\results.json — supports ${variable}"/>

                <CheckBox Content="Overwrite an existing file" IsChecked="{Binding Overwrite}" Margin="0,12,0,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FileOperationStepViewModel}">
            <StackPanel>
                <TextBlock Text="Operation" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox SelectedItem="{Binding Operation}"
                          ItemsSource="{x:Static vm:WorkflowEnumValues.FileOperationKinds}"
                          Width="160" HorizontalAlignment="Left"/>

                <TextBlock Text="Files from" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox IsEditable="True"
                          Text="{Binding SourceStepId, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.SourceStepOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="Destination folder" Style="{StaticResource WfLabelStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding DestinationDirectory, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="Created if missing — supports ${variable}"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Browse..."
                            Command="{Binding BrowseDestinationCommand}"
                            Style="{StaticResource ToolButtonStyle}" Margin="0"/>
                </Grid>

                <TextBlock Text="If the file already exists" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox SelectedItem="{Binding Collision}"
                          ItemsSource="{x:Static vm:WorkflowEnumValues.CollisionPolicies}"
                          Width="160" HorizontalAlignment="Left"/>
                <TextBlock Text="You are asked for confirmation before any files are touched."
                           Style="{StaticResource HintLabelStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RunProgramStepViewModel}">
            <StackPanel>
                <TextBlock Text="Program" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding Program, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="notepad.exe or C:\tools\format.cmd — supports ${variable}"/>

                <TextBlock Text="Arguments" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="&quot;${file}&quot; — supports ${variable}"/>

                <CheckBox Content="Run once per matched file" IsChecked="{Binding PerFile}" Margin="0,12,0,0"/>

                <TextBlock Text="Files from (per-file runs)" Style="{StaticResource WfLabelStyle}"/>
                <ComboBox IsEditable="True"
                          Text="{Binding SourceStepId, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.Workflows.SourceStepOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                          IsEnabled="{Binding PerFile}"/>

                <TextBlock Text="Working directory" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="Optional"/>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Content="Wait for exit" IsChecked="{Binding WaitForExit}" VerticalAlignment="Bottom"/>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Timeout (seconds)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding TimeoutSeconds}" ToolTip="0 waits indefinitely."/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Max files" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding MaxFiles}" ToolTip="Safety cap on per-file launches; 0 means unlimited."/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="You are asked for confirmation before anything is launched."
                           Style="{StaticResource HintLabelStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:StopStepViewModel}">
            <StackPanel>
                <CheckBox Content="Count the run as successful" IsChecked="{Binding Succeeded}" Margin="0,12,0,0"/>
                <TextBlock Text="Message" Style="{StaticResource WfLabelStyle}"/>
                <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="Optional message shown in the run result — supports ${variable}"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Workflows" Style="{StaticResource CtxTitleStyle}"/>
                    <TextBlock Text="{Binding Workflows.StatusText}" Style="{StaticResource MutedValueStyle}" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Click="OnHelpClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="32"
                            MinWidth="80"
                            Padding="12,0"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE897;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Help"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnCloseClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="32"
                            MinWidth="80"
                            Padding="12,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Close"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Library ===== -->
            <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="4,2,4,10">
                        <UniformGrid Columns="2">
                            <Button Command="{Binding Workflows.NewWorkflowCommand}"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Margin="0,0,6,6">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="New"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Workflows.DuplicateWorkflowCommand}"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE8C8;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="Duplicate"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Workflows.DeleteWorkflowCommand}"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE74D;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="Delete"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Workflows.OpenWorkflowsFolderCommand}"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Margin="0"
                                    ToolTip="Open the folder holding the workflow JSON files">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE838;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="Folder"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Workflows.Library}"
                             SelectedItem="{Binding Workflows.SelectedLibraryItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource LibraryListItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedValueStyle}" FontSize="11"/>
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource MutedValueStyle}"
                                               FontSize="11.5"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding Error}"
                                               Foreground="{DynamicResource Atlas.WarmBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ===== Editor + run ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name / description / save -->
                <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                        BorderBrush="{DynamicResource Atlas.LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Workflows.WorkflowName, UpdateSourceTrigger=PropertyChanged}"
                                     ui:ControlHelper.PlaceholderText="Workflow name"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Workflows.WorkflowDescription, UpdateSourceTrigger=PropertyChanged}"
                                     ui:ControlHelper.PlaceholderText="What this workflow does"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                            <TextBlock Text="Unsaved changes"
                                       Style="{StaticResource MutedValueStyle}"
                                       FontSize="11"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,4"
                                       Visibility="{Binding Workflows.IsDirty, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Command="{Binding Workflows.SaveWorkflowCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="32"
                                    MinWidth="96">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE74E;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Save"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step toolbar + run controls -->
                <Grid Grid.Row="1" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Click="OnAddMenuClick" Style="{StaticResource ToolButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Add step"/>
                            <ui:FontIcon Glyph="&#xE70D;" FontSize="9" Margin="7,2,0,0"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Search" Command="{Binding Workflows.AddStepCommand}" CommandParameter="search"/>
                                <MenuItem Header="If (condition)" Command="{Binding Workflows.AddStepCommand}" CommandParameter="if"/>
                                <MenuItem Header="Retry loop" Command="{Binding Workflows.AddStepCommand}" CommandParameter="retry"/>
                                <MenuItem Header="For each file" Command="{Binding Workflows.AddStepCommand}" CommandParameter="forEach"/>
                                <MenuItem Header="Export results" Command="{Binding Workflows.AddStepCommand}" CommandParameter="export"/>
                                <MenuItem Header="Copy / move files" Command="{Binding Workflows.AddStepCommand}" CommandParameter="fileOperation"/>
                                <MenuItem Header="Run program" Command="{Binding Workflows.AddStepCommand}" CommandParameter="runProgram"/>
                                <MenuItem Header="Stop" Command="{Binding Workflows.AddStepCommand}" CommandParameter="stop"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding Workflows.RemoveStepCommand}"
                            Style="{StaticResource ToolButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE74D;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Remove"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding Workflows.MoveStepUpCommand}"
                            Style="{StaticResource ToolButtonStyle}"
                            ToolTip="Move the selected step up within its branch">
                        <ui:FontIcon Glyph="&#xE74A;" FontSize="12"/>
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding Workflows.MoveStepDownCommand}"
                            Style="{StaticResource ToolButtonStyle}"
                            ToolTip="Move the selected step down within its branch">
                        <ui:FontIcon Glyph="&#xE74B;" FontSize="12"/>
                    </Button>

                    <Button Grid.Column="5"
                            Command="{Binding Workflows.RunWorkflowCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="32"
                            MinWidth="92"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE768;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Run"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="6"
                            Command="{Binding Workflows.DryRunWorkflowCommand}"
                            Style="{StaticResource ToolButtonStyle}"
                            ToolTip="Searches and exports run; file operations and program launches are only logged.">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE890;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Dry run"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="7"
                            Command="{Binding Workflows.CancelRunCommand}"
                            Style="{StaticResource ToolButtonStyle}"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Steps + properties -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="6">
                        <ListBox ItemsSource="{Binding Workflows.StepRows}"
                                 SelectedItem="{Binding Workflows.SelectedStep, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource StepListItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="{Binding Indent}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{DynamicResource Atlas.WarmTintBrush}"
                                                    CornerRadius="5"
                                                    Padding="5,1"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasBranchTag, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding BranchTag}"
                                                           Style="{StaticResource WfBadgeTextStyle}"
                                                           Foreground="{DynamicResource Atlas.WarmBrush}"/>
                                            </Border>
                                            <Border Background="{DynamicResource Atlas.AccentTintBrush}"
                                                    CornerRadius="5"
                                                    Padding="5,1"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Kind}"
                                                           Style="{StaticResource WfBadgeTextStyle}"
                                                           Foreground="{DynamicResource Atlas.AccentBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}"
                                                   Style="{StaticResource MutedValueStyle}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Workflows.SelectedStep}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel Margin="0,0,8,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Step id" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Workflows.SelectedStep.Id, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="Unique within the workflow; conditions and scoped steps reference results by this id."/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Display name" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Workflows.SelectedStep.Name, UpdateSourceTrigger=PropertyChanged}"
                                                     ui:ControlHelper.PlaceholderText="Optional — shown in logs"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource Atlas.LineBrush}" Margin="0,14,0,2"/>
                                    <ContentControl Content="{Binding Workflows.SelectedStep}" Focusable="False"/>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="280">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Workflows.SelectedStep}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:FontIcon Glyph="&#xE8FD;" FontSize="38" Opacity="0.22" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No step selected" Style="{StaticResource EmptyTitleStyle}"/>
                                <TextBlock Text="Select a step on the left, or use Add step to build the workflow."
                                           Style="{StaticResource EmptyBodyStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Validation problems -->
                <Border Grid.Row="3"
                        Background="{DynamicResource Atlas.WarmTintBrush}"
                        BorderBrush="{DynamicResource Atlas.WarmBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8"
                        Margin="0,10,0,0"
                        Visibility="{Binding Workflows.HasValidationErrors, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="PROBLEMS"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Atlas.WarmBrush}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Workflows.ValidationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               Foreground="{DynamicResource Atlas.WarmBrush}"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Run output -->
                <Grid Grid.Row="4" Height="220" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RUN LOG" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Workflows.RunStatusText}"
                                           Style="{StaticResource MutedValueStyle}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ListBox x:Name="RunLogList"
                                     ItemsSource="{Binding Workflows.RunLog}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource CompactListItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{DynamicResource Atlas.MonoFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Atlas.Ink2Brush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HITS" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Workflows.RunHitsSummary}"
                                           Style="{StaticResource MutedValueStyle}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ListBox ItemsSource="{Binding Workflows.RunHits}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource CompactListItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="1.6*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Path}"
                                                       ToolTip="{Binding Path}"
                                                       FontFamily="{DynamicResource Atlas.MonoFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Atlas.Ink3Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LineNumber}"
                                                       FontFamily="{DynamicResource Atlas.MonoFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Atlas.AccentBrush}"
                                                       Margin="8,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding LineContent}"
                                                       ToolTip="{Binding LineContent}"
                                                       FontFamily="{DynamicResource Atlas.MonoFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Atlas.Ink2Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
