<Window x:Class="FileSearch.Gui.WorkflowConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="Confirm Workflow Action"
        Width="620"
        Height="460"
        MinWidth="520"
        MinHeight="360"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <StackPanel>
                <TextBlock x:Name="TitleText" Style="{StaticResource CtxTitleStyle}"/>
                <TextBlock x:Name="DescriptionText"
                           Style="{StaticResource MutedValueStyle}"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <Grid Margin="{DynamicResource AppDensity.WindowContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="The workflow is about to perform the following:"
                       Style="{StaticResource FieldLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Grid.Row="1"
                    Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DetailsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="{DynamicResource Atlas.MonoFont}"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource Atlas.Ink2Brush}"
                                           Margin="4,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Click="OnCancelClick"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="84"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>
                <Button Click="OnContinueClick"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="98">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE73E;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Continue"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
