<Window x:Class="FileSearch.Gui.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="FileSearch Help"
        Height="720"
        Width="1000"
        MinHeight="520"
        MinWidth="720"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="User guide" Style="{StaticResource CtxTitleStyle}"/>
                <Button Grid.Column="1"
                        Click="OnCloseClick"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32"
                        MinWidth="80"
                        Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Close"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Margin="12"
                Background="{DynamicResource Atlas.SurfaceBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="HelpWebView"/>
        </Border>
    </DockPanel>
</Window>
