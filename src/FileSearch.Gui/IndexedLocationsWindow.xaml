<Window x:Class="FileSearch.Gui.IndexedLocationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="Indexed Locations"
        Height="560"
        Width="860"
        MinHeight="500"
        MinWidth="760"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Indexed locations" Style="{StaticResource CtxTitleStyle}"/>
                    <TextBlock Text="{Binding Index.IndexedLocationCountText}" Style="{StaticResource MutedValueStyle}" Margin="0,3,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1"
                          Content="Use index for covered searches"
                          IsChecked="{Binding Search.UseIndex, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="4,2,4,10">
                        <Button Command="{Binding Index.AddCurrentFolderToIndexCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE710;" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="{Binding Index.CurrentFolderIndexActionText}"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnAddFolderClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE8B7;" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Add folder..."/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="520"
                                  Margin="4,0,4,10">
                        <Expander Header="NEW INDEX OPTIONS"
                                  IsExpanded="False">
                            <StackPanel Margin="2,8,2,0">
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <CheckBox Content="Subfolders"
                                              IsChecked="{Binding Index.NewIndexRecursive}"
                                              Margin="0,0,8,6"/>
                                    <CheckBox Content="Hidden files"
                                              IsChecked="{Binding Index.NewIndexIncludeHidden}"
                                              Margin="0,0,0,6"/>
                                    <CheckBox Content="Documents"
                                              IsChecked="{Binding Index.NewIndexEnableDocumentExtraction}"
                                              Margin="0,0,8,0"/>
                                    <CheckBox Content="Known types only"
                                              IsChecked="{Binding Index.NewIndexSkipUnknownFileTypes}"
                                              Margin="0"/>
                                </UniformGrid>
                                <TextBlock Text="Include list"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="0,2,0,4"/>
                                <ComboBox ItemsSource="{Binding Index.IndexInclusionLists}"
                                          SelectedItem="{Binding Index.SelectedIndexInclusionList, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Index.NewIndexInclusionListName, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Include list name"
                                         Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Index.NewIndexIncludedExtensions, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Included extensions"
                                         ToolTip="Example: .cs; .md"
                                         Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Index.NewIndexIncludedFolders, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Included folders"
                                         ToolTip="Example: src; tests"
                                         Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Command="{Binding Index.SaveNewIndexInclusionListCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="30"
                                            MinWidth="96"
                                            Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74E;" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Save include"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding Index.RemoveSelectedIndexInclusionListCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="30"
                                            MinWidth="74">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Remove"/>
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>

                                <TextBlock Text="Exclude list"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Index.IndexExclusionLists}"
                                          SelectedItem="{Binding Index.SelectedIndexExclusionList, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Index.NewIndexExclusionListName, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Exclude list name"
                                         Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Index.NewIndexExcludedExtensions, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Excluded extensions"
                                         ToolTip="Example: .dll; .exe; .pdb"
                                         Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Index.NewIndexExcludedFolders, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Excluded folders"
                                         ToolTip="Example: bin; obj"
                                         Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <Button Command="{Binding Index.SaveNewIndexExclusionListCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="30"
                                            MinWidth="96"
                                            Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74E;" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Save exclude"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding Index.RemoveSelectedIndexExclusionListCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="30"
                                            MinWidth="74">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Remove"/>
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Expander>
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,2,0,0">
                        <ListBox ItemsSource="{Binding Index.IndexedLocations}"
                                 SelectedItem="{Binding Index.SelectedIndexedLocation, Mode=TwoWay}"
                                 Style="{StaticResource NavListBoxStyle}"
                                 ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ToolTip="{Binding Root}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Glyph="&#xE8B7;" FontSize="14" Margin="0,0,10,0"
                                                     Foreground="{DynamicResource Atlas.AccentBrush}"
                                                     VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                            <WrapPanel>
                                                <Border Style="{StaticResource IndexStatusBadgeStyle}" Margin="0,3,4,3">
                                                    <TextBlock Text="{Binding RuntimeStatusSummary}"
                                                               Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                                                </Border>
                                                <Border Style="{StaticResource WatchStatusBadgeStyle}" Margin="0,3,0,3">
                                                    <TextBlock Text="{Binding WatchSummary}"
                                                               Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedValueStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource WatchAwareSurfaceStyle}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Index.SelectedIndexedLocation}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel>

                        <TextBlock Text="{Binding Index.SelectedIndexedLocation.DisplayName}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Atlas.InkBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Index.SelectedIndexedLocation.Root}"
                                   ToolTip="{Binding Index.SelectedIndexedLocation.Root}"
                                   Style="{StaticResource MetaValueStyle}"
                                   TextAlignment="Left"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,4,0,18"/>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Status" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    DataContext="{Binding Index.SelectedIndexedLocation}"
                                    Style="{StaticResource IndexStatusBadgeStyle}"
                                    Margin="0,0,0,8">
                                <TextBlock Text="{Binding RuntimeStatusSummary}"
                                           Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                            </Border>

                            <TextBlock Grid.Row="1" Text="Files" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Index.SelectedIndexedLocation.FileCount, StringFormat={}{0:n0}}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="Lines" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Index.SelectedIndexedLocation.LineCount, StringFormat={}{0:n0}}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Text="Refresh" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Index.SelectedIndexedLocation.LastIndexedSummary}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Text="Coverage" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Index.SelectedIndexedLocation.RecursionSummary}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="5" Text="Watcher" Style="{StaticResource MetaKeyStyle}"/>
                            <Border Grid.Row="5" Grid.Column="1"
                                    DataContext="{Binding Index.SelectedIndexedLocation}"
                                    Style="{StaticResource WatchStatusBadgeStyle}">
                                <TextBlock Text="{Binding WatchSummary}"
                                           Style="{StaticResource IndexStatusBadgeTextStyle}"/>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Atlas.LineBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Indexed with" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Text="{Binding Index.SelectedIndexedLocation.TypeSummary}"
                                   Style="{StaticResource MetaValueStyle}"
                                   TextAlignment="Left"
                                   Margin="0,2,0,18"/>

                        <Border Height="1" Background="{DynamicResource Atlas.LineBrush}" Margin="0,0,0,18"/>

                        <TextBlock Text="Database" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid Margin="0,6,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Path" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabasePath}"
                                       ToolTip="{Binding Index.IndexDatabasePath}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="Status" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseStatusText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="Storage" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseSizeText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Text="Content" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseContentText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Text="Queue" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseQueueText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="5" Text="Updated" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseLastIndexedText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="6" Text="Volumes" Style="{StaticResource MetaKeyStyle}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseVolumeHealthText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="7" Text="Diagnostics" Style="{StaticResource MetaKeyStyle}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1"
                                       Text="{Binding Index.IndexDatabaseDiagnosticsText}"
                                       Style="{StaticResource MetaValueStyle}"
                                       TextAlignment="Left"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <WrapPanel>
                            <Button Command="{Binding Index.RebuildSelectedIndexCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="34"
                                    MinWidth="142"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE72C;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Rebuild selected"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Index.RemoveSelectedIndexCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="138"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE74D;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Remove selected"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Index.OpenIndexLocationCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="132"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE838;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Open database"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Index.ExportIndexFailuresCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="132"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE74E;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="Export failures"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding Index.CompactIndexDatabaseCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="146"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE777;" FontSize="13" Margin="0,0,7,0"/>
                                    <TextBlock Text="{Binding Index.CompactIndexDatabaseActionText}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="280">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Index.SelectedIndexedLocation}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:FontIcon Glyph="&#xE8B7;" FontSize="38" Opacity="0.22" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No indexed location selected" Style="{StaticResource EmptyTitleStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Command="{Binding Index.PauseBackgroundIndexingCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        MinWidth="86"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE769;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Pause"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding Index.ResumeBackgroundIndexingCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        MinWidth="92"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE768;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Resume"/>
                    </StackPanel>
                </Button>
                <Button Click="OnCloseClick"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="34"
                        MinWidth="92">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Close"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
