<Window x:Class="FileSearch.Gui.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="About FileSearch"
        Height="520"
        Width="640"
        MinHeight="500"
        MinWidth="580"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <TextBlock Text="About FileSearch" Style="{StaticResource CtxTitleStyle}"/>
        </Border>

        <Grid Margin="{DynamicResource AppDensity.WindowContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                        BorderBrush="{DynamicResource Atlas.LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="Assets/FileSearch-256.png"
                                   Width="72"
                                   Height="72"
                                   Margin="0,0,18,0"
                                   SnapsToDevicePixels="True"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="FileSearch"
                                           FontFamily="{DynamicResource Atlas.SerifFont}"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Atlas.InkBrush}"/>
                                <TextBlock Text="Local file-content search for Windows"
                                           FontSize="14"
                                           Foreground="{DynamicResource Atlas.Ink2Brush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Height="1"
                                Background="{DynamicResource Atlas.LineBrush}"
                                Margin="0,20"/>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Search source files, documents, Office files, PDFs, and other text-backed formats from a focused desktop interface."
                                       FontSize="13.5"
                                       Foreground="{DynamicResource Atlas.Ink2Brush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,18"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Version" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VersionText}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Text="Runtime" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RuntimeText}" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Text="Framework" Style="{StaticResource MetaKeyStyle}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text=".NET 10 WPF" Style="{StaticResource MetaValueStyle}" TextAlignment="Left" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Text="Location" Style="{StaticResource MetaKeyStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding LocationText}"
                                           ToolTip="{Binding LocationText}"
                                           Style="{StaticResource MetaValueStyle}"
                                           TextAlignment="Left"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Click="OnCopyDetailsClick"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="112"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE8C8;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Copy details"/>
                    </StackPanel>
                </Button>
                <Button Click="OnCloseClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="92">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Close"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
