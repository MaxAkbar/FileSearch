<Window x:Class="FileSearch.Gui.RegexTesterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FileSearch.Gui.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:RegexTesterViewModel}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="Regex Tester"
        Width="1020"
        Height="760"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <TextBlock Text="Regex tester" Style="{StaticResource CtxTitleStyle}"/>
        </Border>

        <Grid Margin="{DynamicResource AppDensity.WindowContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="130"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Pattern" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{DynamicResource Atlas.MonoFont}"
                             FontSize="13"
                             Height="38"
                             Margin="0,0,0,12"
                             ui:ControlHelper.PlaceholderText="Regular expression"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <CheckBox Content="Match case"
                                  IsChecked="{Binding MatchCase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,14,0"/>
                        <CheckBox Content="Multiline"
                                  IsChecked="{Binding Multiline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,14,0"/>
                        <CheckBox Content="Singleline"
                                  IsChecked="{Binding Singleline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Test text" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding TestText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="{DynamicResource Atlas.MonoFont}"
                                 FontSize="12"
                                 Padding="10"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Replacement" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding Replacement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{DynamicResource Atlas.MonoFont}"
                                 FontSize="12"
                                 Height="{DynamicResource AppDensity.DialogButtonHeight}"
                                 Margin="0,0,0,12"
                                 ui:ControlHelper.PlaceholderText="Optional replacement"/>
                    </Grid>

                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Replacement preview" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding ReplacementPreview}"
                                 Style="{StaticResource PreviewCodeBoxStyle}"
                                 IsReadOnly="True"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="170"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding MatchSummaryText}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Atlas.InkBrush}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Style="{StaticResource MutedValueStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Matches}"
                             SelectedItem="{Binding SelectedMatch, Mode=TwoWay}"
                             BorderBrush="{DynamicResource Atlas.LineBrush}"
                             Background="{DynamicResource Atlas.Surface2Brush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Summary}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Atlas.Ink2Brush}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding DisplayValue}"
                                               Style="{StaticResource ResultPathStyle}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Text="Groups"
                               Style="{StaticResource FieldLabelStyle}"
                               Margin="0,14,0,8"/>

                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding SelectedMatch.Groups}"
                             BorderBrush="{DynamicResource Atlas.LineBrush}"
                             Background="{DynamicResource Atlas.Surface2Brush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Atlas.Ink2Brush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Location}"
                                               Style="{StaticResource MetaKeyStyle}"
                                               Margin="8,0,8,0"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DisplayValue}"
                                               Style="{StaticResource ResultPathStyle}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Click="OnCloseClick"
                        IsCancel="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="84">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Close"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
