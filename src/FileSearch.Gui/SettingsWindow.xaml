<Window x:Class="FileSearch.Gui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FileSearch.Gui.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ApplicationSettingsViewModel}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="Settings"
        Width="620"
        Height="760"
        MinWidth="560"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <TextBlock Text="Settings" Style="{StaticResource CtxTitleStyle}"/>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="NAVIGATION" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Sidebar page size"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding SidebarPageSizeSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SidebarPageSizeOptions}"
                                  SelectedItem="{Binding SidebarPageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinWidth="110"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1"
                            Background="{DynamicResource Atlas.LineBrush}"
                            Margin="0,18"/>

                    <TextBlock Text="QUICK SEARCH" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Global hotkey"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding QuickSearchHotkeySummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding QuickSearchHotkeyOptions}"
                                  SelectedItem="{Binding QuickSearchHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="150"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Default scope"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding QuickSearchScopeSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding QuickSearchScopeOptions}"
                                  SelectedItem="{Binding QuickSearchDefaultScope, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="210"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Remember last scope"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="When enabled, the quick window opens with the last scope selected there."
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding QuickSearchRememberLastScope, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Include indexed content"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding QuickSearchContentSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding QuickSearchIncludeContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Selected indexed locations"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="Used when the quick window scope is set to selected indexed locations."
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding RefreshQuickIndexedLocationsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34"
                                MinWidth="84"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE72C;" FontSize="12" Margin="0,0,7,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="{DynamicResource Atlas.Surface2Brush}"
                            Padding="10"
                            Margin="0,10,0,0"
                            MaxHeight="130">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QuickIndexedLocationSelections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource ResultPathStyle}"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Height="1"
                            Background="{DynamicResource Atlas.LineBrush}"
                            Margin="0,18"/>

                    <TextBlock Text="THEMES" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Custom JSON theme"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding CustomThemeSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding CustomThemeFolderPath}"
                                       Style="{StaticResource ResultPathStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding CustomThemes}"
                                      SelectedItem="{Binding SelectedCustomTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="DisplayName"
                                      MinWidth="190"
                                      Margin="0,0,8,0"/>
                            <Button Command="{Binding RefreshCustomThemesCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="84"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE72C;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding UseBuiltInThemeCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="34"
                                    MinWidth="96">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE790;" FontSize="12" Margin="0,0,7,0"/>
                                    <TextBlock Text="Built-in"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Height="1"
                            Background="{DynamicResource Atlas.LineBrush}"
                            Margin="0,18"/>

                    <TextBlock Text="INDEXING" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Indexer resource use"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding IndexerResourceProfileSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding IndexerResourceProfileOptions}"
                                  SelectedItem="{Binding IndexerResourceProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinWidth="130"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Pause indexing on battery"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding PauseIndexingOnBatterySummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding PauseIndexingOnBattery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Index only when idle"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding IndexOnlyWhenIdleSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding IndexOnlyWhenIdle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="CPU limit"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding IndexerCpuLimitSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding IndexerCpuLimitOptions}"
                                  SelectedItem="{Binding IndexerCpuLimitPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinWidth="90"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Disk I/O delay"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding IndexerDiskPauseSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding IndexerDiskPauseOptions}"
                                  SelectedItem="{Binding IndexerDiskPauseMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinWidth="90"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1"
                            Background="{DynamicResource Atlas.LineBrush}"
                            Margin="0,18"/>

                    <TextBlock Text="BACKGROUND" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Keep index updated after closing window"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding KeepIndexUpdatedAfterCloseSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding KeepIndexUpdatedAfterClose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Start background indexer when Windows starts"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding StartBackgroundIndexerAtSignInSummary}"
                                       Style="{StaticResource MutedValueStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding StartBackgroundIndexerAtSignIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Command="{Binding ResetNavigationDefaultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        MinWidth="128"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Reset"/>
                    </StackPanel>
                </Button>
                <Button Click="OnCloseClick"
                        IsDefault="True"
                        IsCancel="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="34"
                        MinWidth="84">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE73E;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Done"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
