<Window x:Class="FileSearch.Gui.ScopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/FileSearch.ico"
        Background="{DynamicResource Atlas.PaperBrush}"
        Foreground="{DynamicResource Atlas.InkBrush}"
        FontFamily="{DynamicResource Atlas.SansFont}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Title="New Scope"
        Width="560"
        SizeToContent="Height"
        MinWidth="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource AppRootStyle}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Atlas.PaperBrush}"
                BorderBrush="{DynamicResource Atlas.LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,11">
            <TextBlock Text="New scope" Style="{StaticResource CtxTitleStyle}"/>
        </Border>

        <Grid Margin="{DynamicResource AppDensity.WindowContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource Atlas.SurfaceBrush}"
                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="{DynamicResource AppDensity.SettingsSurfacePadding}">
                <StackPanel>
                    <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="NameBox"
                             Height="38"
                             Margin="0,0,0,18"
                             ui:ControlHelper.PlaceholderText="Scope name"/>

                    <TextBlock Text="Pattern" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PatternBox"
                             Height="38"
                             ui:ControlHelper.PlaceholderText="*.cs;*.xaml;*.md"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Click="OnCancelClick"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="84"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE711;" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>
                <Button Click="OnSaveClick"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="{DynamicResource AppDensity.DialogButtonHeight}"
                        MinWidth="84">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74E;" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Save"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
