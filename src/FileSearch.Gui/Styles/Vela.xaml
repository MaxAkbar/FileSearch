    <Style x:Key="ResultMetaPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.ResultMetaPillPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.ResultMetaPillMargin}"/>
    </Style>

    <Style x:Key="ResultMetaKeyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>

    <Style x:Key="ResultMetaValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MatchLineContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.MatchLinePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.MatchLineMargin}"/>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="MinWidth" Value="16"/>
        <Setter Property="MinHeight" Value="16"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Orientation="{TemplateBinding Orientation}">
                            <Track.Thumb>
                                <Thumb MinWidth="34"
                                       MinHeight="34">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{DynamicResource Atlas.Line2Brush}"
                                                    BorderBrush="{DynamicResource Atlas.LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Margin="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
