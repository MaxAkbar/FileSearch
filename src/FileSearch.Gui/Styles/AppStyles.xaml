        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.OmniBarPadding}"/>
        <Setter Property="Height" Value="{DynamicResource AppDensity.OmniBarHeight}"/>
    </Style>

    <Style x:Key="OmniPathBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="OmniQueryBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="OmniDividerStyle" TargetType="Border">
        <Setter Property="Width" Value="1"/>
