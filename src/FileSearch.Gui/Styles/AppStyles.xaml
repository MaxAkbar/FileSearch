        <Setter Property="Background" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.OmniDividerMargin}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FilterChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.FilterChipPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.FilterChipMargin}"/>
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.FilterChipMinHeight}"/>
    </Style>

    <Style x:Key="QueryChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.QueryChipPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.QueryChipMargin}"/>
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.QueryChipMinHeight}"/>
    </Style>

    <Style x:Key="QueryChipFieldStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>

    <Style x:Key="QueryChipValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MaxWidth" Value="220"/>
    </Style>

    <Style x:Key="ChipLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="MutedValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AdvancedExpanderStyle" TargetType="Expander" BasedOn="{StaticResource {x:Type Expander}}">
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <Style x:Key="AdvancedFlyoutCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.AdvancedFlyoutPadding}"/>
        <Setter Property="MinWidth" Value="560"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.SectionHeaderMargin}"/>
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.FieldLabelMargin}"/>
    </Style>

    <Style x:Key="HintLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.HintLabelMargin}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- =====================================================================
         Results area
         ===================================================================== -->
    <Style x:Key="ResultsSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="CtxTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="ResultsListStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.ResultsListPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
    </Style>

    <!-- Result card = ListBoxItem chrome; the DataTemplate fills the inside. -->
    <Style x:Key="ResultCardContainerStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="{DynamicResource AppDensity.ResultCardMargin}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="card" Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}" BorderThickness="1"
                            CornerRadius="{DynamicResource AppDensity.ResultCardCornerRadius}" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ResultNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="ResultPathStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
    </Style>

    <!-- Type badge (the little coloured square). Background is bound per item
         via the file-type converter; this just sets shape + label typography. -->
    <Style x:Key="TypeBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="{DynamicResource AppDensity.TypeBadgeSize}"/>
        <Setter Property="Height" Value="{DynamicResource AppDensity.TypeBadgeSize}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource AppDensity.TypeBadgeCornerRadius}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TypeBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HitsPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.AccentTintBrush}"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.HitsPillPadding}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HitsPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
    </Style>

    <Style x:Key="LineNoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Width" Value="{DynamicResource AppDensity.LineNoWidth}"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.LineNoMargin}"/>
    </Style>

    <Style x:Key="LineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MoreLinkStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.MoreLinkPadding}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EmptyTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="EmptyBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="320"/>
    </Style>

    <!-- =====================================================================
         Preview pane
         ===================================================================== -->
    <Style x:Key="PreviewPaneStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <Style x:Key="UpperPanelLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="{DynamicResource AppDensity.PreviewBadgeSize}"/>
        <Setter Property="Height" Value="{DynamicResource AppDensity.PreviewBadgeSize}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource AppDensity.PreviewBadgeCornerRadius}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewBadgeTextStyle" TargetType="TextBlock">
