<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:ui="http://schemas.modernwpf.com/2019">

    <!-- =====================================================================
         Atlas design system.

         The Atlas.* brushes below are the LIGHT (paper) defaults. Dark / VS
         overlays (added at runtime by ThemeService) redefine the same keys, so
         our surfaces follow the theme. Built-in ModernWpf controls follow the
         SystemControl* keys, which the same overlays also recolor.
         ===================================================================== -->

    <!-- ===== Palette (Light / paper defaults) ===== -->
    <SolidColorBrush x:Key="Atlas.PaperBrush"      Color="#F4F1EA"/>
    <SolidColorBrush x:Key="Atlas.SurfaceBrush"    Color="#FFFDF8"/>
    <SolidColorBrush x:Key="Atlas.Surface2Brush"   Color="#FAF7F0"/>
    <SolidColorBrush x:Key="Atlas.SidebarBrush"    Color="#EDE8DF"/>
    <SolidColorBrush x:Key="Atlas.InkBrush"        Color="#23261F"/>
    <SolidColorBrush x:Key="Atlas.Ink2Brush"       Color="#5B5F54"/>
    <SolidColorBrush x:Key="Atlas.Ink3Brush"       Color="#8E9286"/>
    <SolidColorBrush x:Key="Atlas.LineBrush"       Color="#17000000"/>
    <SolidColorBrush x:Key="Atlas.Line2Brush"      Color="#29000000"/>
    <SolidColorBrush x:Key="Atlas.HoverBrush"      Color="#0A23261F"/>
    <SolidColorBrush x:Key="Atlas.SelBrush"        Color="#1F2F7D57"/>
    <SolidColorBrush x:Key="Atlas.AccentBrush"     Color="#2F7D57"/>
    <SolidColorBrush x:Key="Atlas.Accent2Brush"    Color="#37926A"/>
    <SolidColorBrush x:Key="Atlas.AccentTintBrush" Color="#1A2F7D57"/>
    <SolidColorBrush x:Key="Atlas.AccentSoftBrush" Color="#0F2F7D57"/>
    <SolidColorBrush x:Key="Atlas.OnAccentBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Atlas.WarmBrush"       Color="#C4722E"/>
    <SolidColorBrush x:Key="Atlas.WarmTintBrush"   Color="#1FC4722E"/>
    <SolidColorBrush x:Key="Atlas.HitBrush"        Color="#8CFFCE54"/>
    <SolidColorBrush x:Key="Atlas.HitInkBrush"     Color="#23261F"/>

    <!-- ===== Typography (Windows fallbacks for the Atlas web fonts) ===== -->
    <FontFamily x:Key="Atlas.SansFont">Segoe UI</FontFamily>
    <FontFamily x:Key="Atlas.SerifFont">Cambria, Georgia, Times New Roman</FontFamily>
    <FontFamily x:Key="Atlas.MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- ===== Density tokens (Comfortable defaults) ===== -->
    <Thickness x:Key="AppDensity.TitleBarPadding">12,6</Thickness>
    <sys:Double x:Key="AppDensity.TitleBarMinHeight">44</sys:Double>
    <Thickness x:Key="AppDensity.StatusBarPadding">18,5</Thickness>
    <Thickness x:Key="AppDensity.SidebarPadding">12,14</Thickness>
    <Thickness x:Key="AppDensity.NavSectionLabelMargin">9,14,0,7</Thickness>
    <Thickness x:Key="AppDensity.NavItemPadding">9,8</Thickness>
    <Thickness x:Key="AppDensity.NavListItemPadding">9,7</Thickness>
    <Thickness x:Key="AppDensity.SidebarSearchBoxPadding">8,4,28,4</Thickness>
    <Thickness x:Key="AppDensity.SidebarSearchBoxMargin">0,2,0,4</Thickness>
    <sys:Double x:Key="AppDensity.SidebarSearchBoxMinHeight">30</sys:Double>
    <Thickness x:Key="AppDensity.BadgePadding">6,2</Thickness>
    <Thickness x:Key="AppDensity.BadgeMargin">0,3,0,3</Thickness>
    <Thickness x:Key="AppDensity.SurfacePadding">20</Thickness>
    <Thickness x:Key="AppDensity.NavSectionMargin">0,0,0,8</Thickness>
    <Thickness x:Key="AppDensity.NavSectionHeaderPadding">10,7</Thickness>
    <Thickness x:Key="AppDensity.NavSectionContentPadding">8,7,8,8</Thickness>
    <sys:Double x:Key="AppDensity.ThemeMiniButtonHeight">28</sys:Double>
    <sys:Double x:Key="AppDensity.CommandButtonHeight">36</sys:Double>
    <sys:Double x:Key="AppDensity.DialogButtonHeight">34</sys:Double>
    <sys:Double x:Key="AppDensity.PrimaryButtonMinWidth">92</sys:Double>
    <sys:Double x:Key="AppDensity.SecondaryButtonMinWidth">80</sys:Double>
    <Thickness x:Key="AppDensity.PrimaryButtonPadding">16,0</Thickness>
    <Thickness x:Key="AppDensity.SecondaryButtonPadding">14,0</Thickness>
    <sys:Double x:Key="AppDensity.ButtonFontSize">13</sys:Double>
    <sys:Double x:Key="AppDensity.IconButtonSize">34</sys:Double>
    <sys:Double x:Key="AppDensity.SmallIconButtonSize">24</sys:Double>
    <sys:Double x:Key="AppDensity.TinyIconButtonSize">22</sys:Double>
    <sys:Double x:Key="AppDensity.PreviewIconButtonSize">28</sys:Double>
    <sys:Double x:Key="AppDensity.OmniBarHeight">38</sys:Double>
    <Thickness x:Key="AppDensity.OmniBarPadding">12,0</Thickness>
    <Thickness x:Key="AppDensity.OmniDividerMargin">10,0</Thickness>
    <Thickness x:Key="AppDensity.FilterChipPadding">11,6</Thickness>
    <Thickness x:Key="AppDensity.FilterChipMargin">0,0,8,8</Thickness>
    <sys:Double x:Key="AppDensity.FilterChipMinHeight">34</sys:Double>
    <Thickness x:Key="AppDensity.QueryChipPadding">9,4</Thickness>
    <Thickness x:Key="AppDensity.QueryChipMargin">0,0,7,7</Thickness>
    <sys:Double x:Key="AppDensity.QueryChipMinHeight">30</sys:Double>
    <Thickness x:Key="AppDensity.AdvancedFlyoutPadding">16</Thickness>
    <Thickness x:Key="AppDensity.SectionHeaderMargin">0,0,0,10</Thickness>
    <Thickness x:Key="AppDensity.FieldLabelMargin">0,0,0,4</Thickness>
    <Thickness x:Key="AppDensity.HintLabelMargin">0,4,0,0</Thickness>
    <Thickness x:Key="AppDensity.ResultsListPadding">0,2,4,8</Thickness>
    <Thickness x:Key="AppDensity.ResultCardMargin">0,0,0,8</Thickness>
    <CornerRadius x:Key="AppDensity.ResultCardCornerRadius">12</CornerRadius>
    <sys:Double x:Key="AppDensity.TypeBadgeSize">30</sys:Double>
    <CornerRadius x:Key="AppDensity.TypeBadgeCornerRadius">8</CornerRadius>
    <Thickness x:Key="AppDensity.HitsPillPadding">10,3</Thickness>
    <sys:Double x:Key="AppDensity.LineNoWidth">46</sys:Double>
    <Thickness x:Key="AppDensity.LineNoMargin">0,0,14,0</Thickness>
    <Thickness x:Key="AppDensity.MoreLinkPadding">15,7</Thickness>
    <sys:Double x:Key="AppDensity.PreviewBadgeSize">60</sys:Double>
    <CornerRadius x:Key="AppDensity.PreviewBadgeCornerRadius">14</CornerRadius>
    <Thickness x:Key="AppDensity.PreviewNameMargin">0,10,0,0</Thickness>
    <Thickness x:Key="AppDensity.PreviewCodePadding">10</Thickness>
    <Thickness x:Key="AppDensity.WindowContentMargin">20</Thickness>
    <Thickness x:Key="AppDensity.SettingsSurfacePadding">20</Thickness>
    <Thickness x:Key="AppDensity.MainContentMargin">14,14,8,12</Thickness>
    <Thickness x:Key="AppDensity.ResultHeaderMargin">2,0,2,10</Thickness>
    <Thickness x:Key="AppDensity.ResultCardInnerMargin">15,12,15,12</Thickness>
    <Thickness x:Key="AppDensity.PreviewHeaderPadding">16,14,14,12</Thickness>
    <Thickness x:Key="AppDensity.PreviewActionMargin">16,12,16,16</Thickness>
    <Thickness x:Key="AppDensity.PreviewBodyMargin">16,16,16,8</Thickness>
    <Thickness x:Key="AppDensity.QuickSearchPadding">12</Thickness>
    <sys:Double x:Key="AppDensity.QuickSearchOmniBarHeight">44</sys:Double>
    <sys:Double x:Key="AppDensity.QuickFolderButtonSize">30</sys:Double>
    <Thickness x:Key="AppDensity.QuickResultCardInnerMargin">12,10</Thickness>
    <sys:Double x:Key="AppDensity.QuickLineNoWidth">34</sys:Double>

    <!-- =====================================================================
         Shell
         ===================================================================== -->
    <Style x:Key="AppRootStyle" TargetType="DockPanel">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
    </Style>

    <Style x:Key="ShellStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ===== Title bar ===== -->
    <Style x:Key="TitleBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.TitleBarPadding}"/>
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.TitleBarMinHeight}"/>
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
    </Style>

    <Style x:Key="TitleMenuStyle" TargetType="Menu" BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ===== Status bar ===== -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.StatusBarPadding}"/>
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="StatusStrongStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- =====================================================================
         Sidebar
         ===================================================================== -->
    <Style x:Key="SidebarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SidebarBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.SidebarPadding}"/>
    </Style>

    <Style x:Key="LogoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="NavSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.NavSectionLabelMargin}"/>
    </Style>

    <!-- Sidebar command rows (Scopes presets, footer actions) -->
    <Style x:Key="NavItemButtonStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.NavItemPadding}"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Recent folders / Saved finds lists -->
    <Style x:Key="NavListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <!-- The sidebar sections scroll as a single surface, so the list must
             not be a scroll host itself: drop the default template's
             ScrollViewer (which would swallow mouse-wheel events even when it
             has nothing to scroll) and size the list to its items. -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <ItemsPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.NavListItemPadding}"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!-- Full value (path / query) on hover, since rows can be truncated. -->
        <Setter Property="ToolTip" Value="{Binding}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.SelBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarSearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.SidebarSearchBoxMinHeight}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.SidebarSearchBoxPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.SidebarSearchBoxMargin}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="SidebarPagerTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="IndexStatusBadgeStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.BadgePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.BadgeMargin}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsQueued}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.WarmTintBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.WarmBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.WarmBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsIndexing}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentTintBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsIndexingPaused}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Ink3Brush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="IndexStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="WatchStatusBadgeStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.BadgePadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.BadgeMargin}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding WatchEnabled}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WatchAwareSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.SurfacePadding}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Index.SelectedIndexedLocation.WatchEnabled}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Collapsible sidebar section header (SCOPES / RECENT FOLDERS / SAVED FINDS). -->
    <Style x:Key="NavSectionExpanderStyle" TargetType="Expander">
        <Setter Property="IsExpanded" Value="True"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.NavSectionMargin}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border x:Name="SectionChrome"
                            Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          DockPanel.Dock="Top"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          Cursor="Hand"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          FocusVisualStyle="{x:Null}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderBg"
                                                Background="{DynamicResource Atlas.Surface2Brush}"
                                                BorderBrush="{DynamicResource Atlas.LineBrush}"
                                                BorderThickness="0,0,0,1"
                                                CornerRadius="8,8,0,0"
                                                Padding="{DynamicResource AppDensity.NavSectionHeaderPadding}"
                                                SnapsToDevicePixels="True"
                                                TextElement.FontSize="10.5" TextElement.FontWeight="Bold"
                                                TextElement.Foreground="{DynamicResource Atlas.Ink3Brush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                                <ui:FontIcon x:Name="Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                                             FontSize="9" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource Atlas.Ink3Brush}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderBg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="Chevron" Property="Glyph" Value="&#xE76C;"/>
                                                <Setter TargetName="HeaderBg" Property="BorderThickness" Value="0"/>
                                                <Setter TargetName="HeaderBg" Property="CornerRadius" Value="8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="SectionContent"
                                     Padding="{DynamicResource AppDensity.NavSectionContentPadding}"
                                    Visibility="Collapsed">
                                <ContentPresenter ContentSource="Content"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="SectionContent" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SectionChrome" Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThemeMiniButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource AppDensity.ThemeMiniButtonHeight}"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Atlas.Line2Brush}" BorderThickness="1"
                            CornerRadius="7" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         Buttons (omni / command bar)
         ===================================================================== -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource AppDensity.CommandButtonHeight}"/>
        <Setter Property="MinWidth" Value="{DynamicResource AppDensity.PrimaryButtonMinWidth}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.PrimaryButtonPadding}"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.OnAccentBrush}"/>
        <Setter Property="FontSize" Value="{DynamicResource AppDensity.ButtonFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="9"
                            SnapsToDevicePixels="True" TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Accent2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource AppDensity.CommandButtonHeight}"/>
        <Setter Property="MinWidth" Value="{DynamicResource AppDensity.SecondaryButtonMinWidth}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.SecondaryButtonPadding}"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="{DynamicResource AppDensity.ButtonFontSize}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Atlas.Line2Brush}" BorderThickness="1"
                            CornerRadius="9" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource AppDensity.IconButtonSize}"/>
        <Setter Property="Height" Value="{DynamicResource AppDensity.IconButtonSize}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            SnapsToDevicePixels="True" TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         Omni bar + filters
         ===================================================================== -->
    <Style x:Key="OmniBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
