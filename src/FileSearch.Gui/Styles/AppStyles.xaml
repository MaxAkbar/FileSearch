    <!-- =====================================================================
         Shell
         ===================================================================== -->
    <Style x:Key="AppRootStyle" TargetType="DockPanel">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
    </Style>

    <Style x:Key="ShellStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ===== Title bar ===== -->
    <Style x:Key="TitleBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.TitleBarPadding}"/>
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.TitleBarMinHeight}"/>
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
    </Style>

    <Style x:Key="TitleSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="TitleDividerStyle" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="Margin" Value="14,0,2,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TitleMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
        <Setter Property="Background" Value="{DynamicResource AppStyle.TitleMenuItemBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.TitleMenuItemPadding}"/>
        <Setter Property="MinHeight" Value="{DynamicResource AppDensity.TitleMenuItemMinHeight}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="TitleMenuStyle" TargetType="Menu" BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="Background" Value="{DynamicResource AppStyle.TitleMenuBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource TitleMenuItemStyle}"/>
    </Style>

    <Style x:Key="TitleStatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppStyle.TitleStatusPillBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppStyle.TitleStatusPillBorderBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource AppStyle.TitleStatusPillBorderThickness}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource AppStyle.TitleStatusPillCornerRadius}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.TitleStatusPillPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.TitleStatusPillMargin}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===== Status bar ===== -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.StatusBarPadding}"/>
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="StatusStrongStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppStyle.StatusPillBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppStyle.StatusPillBorderBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource AppStyle.StatusPillBorderThickness}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource AppStyle.StatusPillCornerRadius}"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.StatusPillPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource AppDensity.StatusPillMargin}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- =====================================================================
         Sidebar
         ===================================================================== -->
    <Style x:Key="SidebarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SidebarBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Padding" Value="{DynamicResource AppDensity.SidebarPadding}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
    </Style>

    <Style x:Key="LogoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
