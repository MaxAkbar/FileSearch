    <Color x:Key="Atlas.InkColor">#23261F</Color>
    <Color x:Key="Atlas.Ink2Color">#5B5F54</Color>
    <Color x:Key="Atlas.Ink3Color">#8E9286</Color>
    <Color x:Key="Atlas.LineColor">#17000000</Color>
    <Color x:Key="Atlas.Line2Color">#29000000</Color>
    <Color x:Key="Atlas.HoverColor">#0A23261F</Color>
