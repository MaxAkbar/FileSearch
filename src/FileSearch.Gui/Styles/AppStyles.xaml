<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.modernwpf.com/2019">

    <!-- =====================================================================
         Atlas design system.

         The Atlas.* brushes below are the LIGHT (paper) defaults. Dark / VS
         overlays (added at runtime by ThemeService) redefine the same keys, so
         our surfaces follow the theme. Built-in ModernWpf controls follow the
         SystemControl* keys, which the same overlays also recolor.
         ===================================================================== -->

    <!-- ===== Palette (Light / paper defaults) ===== -->
    <SolidColorBrush x:Key="Atlas.PaperBrush"      Color="#F4F1EA"/>
    <SolidColorBrush x:Key="Atlas.SurfaceBrush"    Color="#FFFDF8"/>
    <SolidColorBrush x:Key="Atlas.Surface2Brush"   Color="#FAF7F0"/>
    <SolidColorBrush x:Key="Atlas.SidebarBrush"    Color="#EDE8DF"/>
    <SolidColorBrush x:Key="Atlas.InkBrush"        Color="#23261F"/>
    <SolidColorBrush x:Key="Atlas.Ink2Brush"       Color="#5B5F54"/>
    <SolidColorBrush x:Key="Atlas.Ink3Brush"       Color="#8E9286"/>
    <SolidColorBrush x:Key="Atlas.LineBrush"       Color="#17000000"/>
    <SolidColorBrush x:Key="Atlas.Line2Brush"      Color="#29000000"/>
    <SolidColorBrush x:Key="Atlas.HoverBrush"      Color="#0A23261F"/>
    <SolidColorBrush x:Key="Atlas.SelBrush"        Color="#1F2F7D57"/>
    <SolidColorBrush x:Key="Atlas.AccentBrush"     Color="#2F7D57"/>
    <SolidColorBrush x:Key="Atlas.Accent2Brush"    Color="#37926A"/>
    <SolidColorBrush x:Key="Atlas.AccentTintBrush" Color="#1A2F7D57"/>
    <SolidColorBrush x:Key="Atlas.AccentSoftBrush" Color="#0F2F7D57"/>
    <SolidColorBrush x:Key="Atlas.OnAccentBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Atlas.WarmBrush"       Color="#C4722E"/>
    <SolidColorBrush x:Key="Atlas.WarmTintBrush"   Color="#1FC4722E"/>
    <SolidColorBrush x:Key="Atlas.HitBrush"        Color="#8CFFCE54"/>
    <SolidColorBrush x:Key="Atlas.HitInkBrush"     Color="#23261F"/>

    <!-- ===== Typography (Windows fallbacks for the Atlas web fonts) ===== -->
    <FontFamily x:Key="Atlas.SansFont">Segoe UI</FontFamily>
    <FontFamily x:Key="Atlas.SerifFont">Cambria, Georgia, Times New Roman</FontFamily>
    <FontFamily x:Key="Atlas.MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- =====================================================================
         Shell
         ===================================================================== -->
    <Style x:Key="AppRootStyle" TargetType="DockPanel">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
    </Style>

    <Style x:Key="ShellStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ===== Title bar ===== -->
    <Style x:Key="TitleBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
    </Style>

    <Style x:Key="TitleMenuStyle" TargetType="Menu" BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ===== Status bar ===== -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.PaperBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="18,5"/>
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="StatusStrongStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- =====================================================================
         Sidebar
         ===================================================================== -->
    <Style x:Key="SidebarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SidebarBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Padding" Value="12,14"/>
    </Style>

    <Style x:Key="LogoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="NavSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="9,14,0,7"/>
    </Style>

    <!-- Sidebar command rows (Scopes presets, footer actions) -->
    <Style x:Key="NavItemButtonStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Padding" Value="9,8"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Recent folders / Saved finds lists -->
    <Style x:Key="NavListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <!-- Each section owns a weighted row; let the list scroll within it when
             its items exceed the space the row was given. -->
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!-- Full value (path / query) on hover, since rows can be truncated. -->
        <Setter Property="ToolTip" Value="{Binding}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.SelBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IndexStatusBadgeStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,3,0,3"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsQueued}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.WarmTintBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.WarmBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.WarmBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsIndexing}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentTintBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsIndexingPaused}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Ink3Brush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="IndexStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="WatchStatusBadgeStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,3,0,3"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding WatchEnabled}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WatchAwareSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedIndexedLocation.WatchEnabled}" Value="True">
                <Setter Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Collapsible sidebar section header (SCOPES / RECENT FOLDERS / SAVED FINDS).
         Minimal Atlas styling: an uppercase label that toggles a chevron and
         shows/hides its content; no Expander chrome. -->
    <Style x:Key="NavSectionExpanderStyle" TargetType="Expander">
        <Setter Property="IsExpanded" Value="True"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <DockPanel>
                        <ToggleButton x:Name="HeaderToggle"
                                      DockPanel.Dock="Top"
                                      Content="{TemplateBinding Header}"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"
                                      Cursor="Hand"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="HeaderBg" Background="Transparent" CornerRadius="8"
                                            Padding="9,6" SnapsToDevicePixels="True"
                                            TextElement.FontSize="10.5" TextElement.FontWeight="Bold"
                                            TextElement.Foreground="{DynamicResource Atlas.Ink3Brush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                            <ui:FontIcon x:Name="Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                                         FontSize="9" VerticalAlignment="Center"
                                                         Foreground="{DynamicResource Atlas.Ink3Brush}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HeaderBg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="Chevron" Property="Glyph" Value="&#xE76C;"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="SectionContent" Visibility="Collapsed" Margin="0,2,0,2"/>
                    </DockPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="SectionContent" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThemeMiniButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Atlas.Line2Brush}" BorderThickness="1"
                            CornerRadius="7" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         Buttons (omni / command bar)
         ===================================================================== -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="92"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.OnAccentBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="9"
                            SnapsToDevicePixels="True" TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Accent2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Atlas.Line2Brush}" BorderThickness="1"
                            CornerRadius="9" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                            SnapsToDevicePixels="True" TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.HoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         Omni bar + filters
         ===================================================================== -->
    <Style x:Key="OmniBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="38"/>
    </Style>

    <Style x:Key="OmniPathBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="OmniQueryBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="OmniDividerStyle" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.Line2Brush}"/>
        <Setter Property="Margin" Value="10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FilterChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>

    <Style x:Key="ChipLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="MutedValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AdvancedExpanderStyle" TargetType="Expander" BasedOn="{StaticResource {x:Type Expander}}">
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <Style x:Key="AdvancedFlyoutCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="MinWidth" Value="560"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="HintLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- =====================================================================
         Results area
         ===================================================================== -->
    <Style x:Key="ResultsSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="CtxTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="ResultsListStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0,2,4,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
    </Style>

    <!-- Result card = ListBoxItem chrome; the DataTemplate fills the inside. -->
    <Style x:Key="ResultCardContainerStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="card" Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}" BorderThickness="1"
                            CornerRadius="12" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ResultNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="ResultPathStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
    </Style>

    <!-- Type badge (the little coloured square). Background is bound per item
         via the file-type converter; this just sets shape + label typography. -->
    <Style x:Key="TypeBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TypeBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HitsPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.AccentTintBrush}"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HitsPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
    </Style>

    <Style x:Key="LineNoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0,0,14,0"/>
    </Style>

    <Style x:Key="LineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MoreLinkStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.AccentBrush}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Padding" Value="15,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Atlas.AccentSoftBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EmptyTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="EmptyBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="320"/>
    </Style>

    <!-- =====================================================================
         Preview pane
         ===================================================================== -->
    <Style x:Key="PreviewPaneStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Atlas.Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <Style x:Key="UpperPanelLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewNameStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.SerifFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>

    <Style x:Key="MetaKeyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink3Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MetaValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.InkBrush}"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PreviewCodeBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="FontFamily" Value="{DynamicResource Atlas.MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{DynamicResource Atlas.Ink2Brush}"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Atlas.LineBrush}"/>
        <Setter Property="Background" Value="{DynamicResource Atlas.SurfaceBrush}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style x:Key="PreviewActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="0"/>
    </Style>

    <Style x:Key="SecondaryPreviewActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="0"/>
    </Style>

    <!-- ===== Preview splitter ===== -->
    <Style x:Key="PreviewGridSplitterStyle" TargetType="GridSplitter">
        <Setter Property="Width" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
        <Setter Property="ResizeDirection" Value="Columns"/>
        <Setter Property="ShowsPreview" Value="False"/>
        <Setter Property="Cursor" Value="SizeWE"/>
        <Setter Property="ToolTip" Value="Drag to resize preview"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsPreviewPaneVisible}" Value="False">
                <Setter Property="Width" Value="0"/>
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="IsHitTestVisible" Value="False"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
