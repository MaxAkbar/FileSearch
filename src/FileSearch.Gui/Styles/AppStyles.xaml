        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="card" Background="{DynamicResource Atlas.SurfaceBrush}"
                            BorderBrush="{DynamicResource Atlas.LineBrush}" BorderThickness="1"
                            CornerRadius="{DynamicResource AppDensity.ResultCardCornerRadius}" SnapsToDevicePixels="True">
                        <Grid>
                            <Border x:Name="AccentRail"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource Atlas.AccentBrush}"
                                    Visibility="{DynamicResource AppStyle.ResultAccentRailVisibility}"
                                    Opacity="0"/>
                            <ContentPresenter/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.Line2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="card" Property="Background" Value="{DynamicResource Atlas.SelBrush}"/>
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource Atlas.AccentBrush}"/>
                            <Setter TargetName="AccentRail" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
